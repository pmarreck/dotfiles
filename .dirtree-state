# Dirtree: Stateful directory trees in the CLI for humans and LLMs. https://github.com/pmarreck/dirtree
ver=1.2
default=closed

depth=3

open=[
	bin
]

close=[
	bin/src
	bin/test
]

hide=[
	.git
	.gitconfig.old-possibly-useful
	.jj
	.netrc.gpg
	.secrets
	.secrets.gpg
	Library
	of_historical_note
]

annotate=[
	bin/base85 = LuaJIT base85 encode/decode (Z85/ZeroMQ default, Adobe ASCII85 via -A); stdin only, --encode/--decode/auto-detect alphabet+direction; Z85 arbitrary-length via BLIP-pad wrapper (-p/-P to force/disable)
	bin/checksite = Poll a URL until response stops matching a down-pattern, then alert (tput bel); --once/--input - for offline testing
	bin/exclude = filter OUT stdin lines matching a ripgrep regex (rg --invert-match wrapper, inverse of include)
	bin/gum-demo = Interactive walkthrough of the gum TUI tool's features
	bin/include = keep only stdin lines matching a ripgrep regex (rg wrapper, inverse of exclude)
	bin/jj-reattach-head = attach git HEAD to the bookmark on jj's @- (cures post-jj-commit detached HEAD)
	bin/md-section = list markdown headings / extract the section under one (fence-aware, level-aware, derives TOC from headings; LuaJIT)
	bin/nas = cross-platform NAS mount helper (macOS/Linux/NixOS); imperative-default + --persist/--unpersist/--dry-run; idempotent automount config
	bin/nas.ps1 = Windows PowerShell counterpart to bin/nas; SMB (default) or NFS via -Protocol; -DriveLetter -Persist -DryRun -NoOpen -Help
	bin/rule30 = Terminal Wolfram Rule 30 cellular-automaton visualizer; WIDTH/LINES env overrides
	bin/test/block-attribution_test = tests the global PreToolUse hook that blocks AI authorship trailers (hook at ~/.claude/hooks/block-attribution/)
	bin/test/exclude_test = test suite for bin/exclude (semantics + --help regression guards)
	bin/test/fun_intro_test = tests for capability-bucketed fun_intro cache (image_capable/image_incapable, hardlink invariant)
	bin/test/include_test = test suite for bin/include (semantics + --help regression guards)
	bin/test/jj-reattach-head_test = tests for jj-reattach-head (single/multi/no-bookmark cases, explicit-arg override, idempotency)
	bin/test/nas_ps1_test = static-content validation for bin/nas.ps1 (no pwsh required locally); checks param block, both protocol branches, safety helpers, mojibake hygiene; opportunistic pwsh parse if available
	bin/test/nas_test = TDD coverage for bin/nas: pure helpers (_nas_fstab_line, _nas_nixos_snippet, _nas_auto_nfs_line), platform override, --help, --dry-run for all three OS branches
	bin/webserver.awk = Tiny awk-based HTTP file server (via socat), kept in awk as a capability demo
]
