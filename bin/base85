#!/usr/bin/env luajit

local buffer = require('string.buffer')
local ffi = require('ffi')

local ABOUT = 'base85: encode/decode base85 (Z85/ZeroMQ or Adobe ASCII85) between binary and text, stdin only, to stdout'

local HELP = [[
Usage: base85 [OPTIONS] < input > output

Encodes or decodes base85. Reads stdin only, writes to stdout. Supports two
alphabets: Z85 (ZeroMQ, RFC 32) and Adobe ASCII85. With no mode flag,
auto-detects: input containing any byte outside both alphabets (and
whitespace) is treated as binary and encoded; input that looks like base85
text is decoded. With no alphabet flag, encoding defaults to Z85 (it has no
backslash/quote characters, so it's friendlier to embed); decoding
auto-detects which alphabet the text uses, defaulting to Z85 if ambiguous.

Z85 requires input length to be an exact multiple of 4 bytes (5 characters
on decode) -- this matches the reference ZeroMQ implementation, which has no
partial-group padding scheme. Adobe ASCII85 supports any length.

Options:
  -e, --encode   Force encode mode (binary -> base85 text)
  -d, --decode   Force decode mode (base85 text -> binary)
  -z, --zeromq   Use the Z85 (ZeroMQ) alphabet
  -A, --adobe    Use the Adobe ASCII85 alphabet
  -a, --about    Show a short description of the tool
  -h, --help     Show this help message
      --test     Run bin/test/base85_test with stdout suppressed
]]

local MAX_U32 = 4294967295

local WHITESPACE = { [32] = true, [9] = true, [10] = true, [13] = true }

local function build_codec(alphabet, allow_partial, contiguous_offset)
	local char = {}
	local digit = {}
	for i = 1, #alphabet do
		local b = alphabet:byte(i)
		char[i - 1] = b
		digit[b] = i - 1
	end
	-- contiguous_offset lets encode() skip the char[] table lookup for
	-- alphabets that are just a contiguous byte range (byte = offset + digit).
	-- Measured: table lookup vs. scalar add costs ~40% at the 10MB scale,
	-- even though the table (85 entries) easily fits in L1 -- indirection
	-- through a table isn't free, so skip it whenever arithmetic is exact.
	return { char = char, digit = digit, allow_partial = allow_partial, contiguous_offset = contiguous_offset }
end

local ADOBE_ALPHABET
do
	local bytes = {}
	for b = 33, 117 do
		bytes[#bytes + 1] = b
	end
	ADOBE_ALPHABET = string.char(unpack(bytes))
end

-- Z85 (ZeroMQ RFC 32): no backslash/quote characters, unlike Adobe ASCII85,
-- which makes it safer to embed in C strings / JSON / shell without escaping.
-- Not a contiguous byte range, so it has no arithmetic fast path.
local Z85_ALPHABET = '0123456789abcdefghijklmnopqrstuvwxyzABCDEFGHIJKLMNOPQRSTUVWXYZ.-:+=^!/*?&<>()[]{}@%$#'

local ADOBE = build_codec(ADOBE_ALPHABET, true, 33)
local ZEROMQ = build_codec(Z85_ALPHABET, false, nil)

local function stderr(msg)
	io.stderr:write(msg, '\n')
end

local function read_stdin()
	local data = io.stdin:read('*a')
	return data or ''
end

local function encode(data, codec)
	local len = #data
	local full = len - (len % 4)
	local remain = len - full
	if remain > 0 and not codec.allow_partial then
		error('base85: this alphabet requires input length to be a multiple of 4 bytes (got ' .. len .. ')', 0)
	end
	local out_len = (full / 4) * 5 + (remain > 0 and (remain + 1) or 0)

	local char = codec.char
	local offset = codec.contiguous_offset
	local buf = buffer.new()
	-- FFI write path: no per-group string allocation (vs. string.char + :put).
	-- Reserve the whole (exact) output once and write bytes directly through
	-- the pointer; no other buffer method may run until :commit (invalidates ptr).
	local ptr = buf:reserve(out_len > 0 and out_len or 1)
	local p = ffi.cast('uint8_t*', ptr)
	local o = 0
	local i = 1
	if offset then
		-- contiguous alphabet: byte = offset + digit, no table indirection
		while i <= full do
			local b0, b1, b2, b3 = data:byte(i, i + 3)
			local num = ((b0 * 256 + b1) * 256 + b2) * 256 + b3
			local d4 = num % 85; num = (num - d4) / 85
			local d3 = num % 85; num = (num - d3) / 85
			local d2 = num % 85; num = (num - d2) / 85
			local d1 = num % 85; num = (num - d1) / 85
			local d0 = num
			p[o] = offset + d0
			p[o + 1] = offset + d1
			p[o + 2] = offset + d2
			p[o + 3] = offset + d3
			p[o + 4] = offset + d4
			o = o + 5
			i = i + 4
		end
	else
		while i <= full do
			local b0, b1, b2, b3 = data:byte(i, i + 3)
			local num = ((b0 * 256 + b1) * 256 + b2) * 256 + b3
			local d4 = num % 85; num = (num - d4) / 85
			local d3 = num % 85; num = (num - d3) / 85
			local d2 = num % 85; num = (num - d2) / 85
			local d1 = num % 85; num = (num - d1) / 85
			local d0 = num
			p[o] = char[d0]
			p[o + 1] = char[d1]
			p[o + 2] = char[d2]
			p[o + 3] = char[d3]
			p[o + 4] = char[d4]
			o = o + 5
			i = i + 4
		end
	end
	if remain > 0 then
		local b0 = data:byte(i)
		local b1 = remain >= 2 and data:byte(i + 1) or 0
		local b2 = remain >= 3 and data:byte(i + 2) or 0
		-- pad the missing low-order bytes with zero, then keep only the
		-- leading (remain + 1) digits of the resulting 5-digit group
		local num = ((b0 * 256 + b1) * 256 + b2) * 256
		local d4 = num % 85; num = (num - d4) / 85
		local d3 = num % 85; num = (num - d3) / 85
		local d2 = num % 85; num = (num - d2) / 85
		local d1 = num % 85; num = (num - d1) / 85
		local d0 = num
		local digits = { d0, d1, d2, d3, d4 }
		for k = 1, remain + 1 do
			p[o] = offset and (offset + digits[k]) or char[digits[k]]
			o = o + 1
		end
	end
	buf:commit(o)
	return buf:get()
end

local function unpack_group(d0, d1, d2, d3, d4)
	local num = ((((d0 * 85 + d1) * 85 + d2) * 85 + d3) * 85 + d4)
	if num > MAX_U32 then
		error('base85: invalid sequence (value out of range)', 0)
	end
	local b3 = num % 256; num = (num - b3) / 256
	local b2 = num % 256; num = (num - b2) / 256
	local b1 = num % 256; num = (num - b1) / 256
	local b0 = num
	return b0, b1, b2, b3
end

local function decode(text, codec)
	-- gsub always copies the whole string even with zero matches; skip that
	-- copy on the common case (no whitespace at all) via a cheap find first
	local clean = text:find('[ \t\r\n]') and (text:gsub('[ \t\r\n]', '')) or text
	local n = #clean
	local digit = codec.digit
	if codec.allow_partial then
		if n % 5 == 1 then
			error('base85: truncated input (trailing single character)', 0)
		end
	elseif n % 5 ~= 0 then
		error('base85: this alphabet requires input length to be a multiple of 5 characters (got ' .. n .. ')', 0)
	end
	local full = n - (n % 5)
	local remain = n - full
	local out_len = (full / 5) * 4 + (remain > 0 and (remain - 1) or 0)

	local buf = buffer.new()
	local ptr = buf:reserve(out_len > 0 and out_len or 1)
	local p = ffi.cast('uint8_t*', ptr)
	local o = 0
	local i = 1
	while i <= full do
		local c0, c1, c2, c3, c4 = clean:byte(i, i + 4)
		local d0, d1, d2, d3, d4 = digit[c0], digit[c1], digit[c2], digit[c3], digit[c4]
		if not (d0 and d1 and d2 and d3 and d4) then
			error('base85: invalid character in input', 0)
		end
		local b0, b1, b2, b3 = unpack_group(d0, d1, d2, d3, d4)
		p[o] = b0
		p[o + 1] = b1
		p[o + 2] = b2
		p[o + 3] = b3
		o = o + 4
		i = i + 5
	end
	if remain > 0 then
		local digits = { clean:byte(i, i + remain - 1) }
		for k = 1, remain do
			local d = digit[digits[k]]
			if not d then
				error('base85: invalid character in input', 0)
			end
			digits[k] = d
		end
		-- pad missing trailing digits with 84 (the max digit), then keep
		-- only the leading (remain - 1) bytes of the decoded group
		for k = remain + 1, 5 do
			digits[k] = 84
		end
		local bytes = { unpack_group(digits[1], digits[2], digits[3], digits[4], digits[5]) }
		for k = 1, remain - 1 do
			p[o] = bytes[k]
			o = o + 1
		end
	end
	buf:commit(o)
	return buf:get()
end

-- Classifies stdin as 'binary', 'adobe', or 'zeromq'. When bytes are valid
-- in both alphabets (fully ambiguous, or empty input) this resolves to
-- 'zeromq' -- the stated default for encode also governs decode ambiguity.
local function classify(data)
	local could_be_adobe = true
	local could_be_z85 = true
	for i = 1, #data do
		local b = data:byte(i)
		if not WHITESPACE[b] then
			if not ADOBE.digit[b] then could_be_adobe = false end
			if not ZEROMQ.digit[b] then could_be_z85 = false end
			if not could_be_adobe and not could_be_z85 then
				return 'binary'
			end
		end
	end
	if could_be_z85 then
		return 'zeromq'
	elseif could_be_adobe then
		return 'adobe'
	end
	return 'binary'
end

local function parse_args(argv)
	local options = {}
	local i = 1
	while i <= #argv do
		local a = argv[i]
		if a == '-h' or a == '--help' then
			options.help = true
		elseif a == '-a' or a == '--about' then
			options.about = true
		elseif a == '--test' then
			options.test = true
		elseif a == '-e' or a == '--encode' then
			options.mode = 'encode'
		elseif a == '-d' or a == '--decode' then
			options.mode = 'decode'
		elseif a == '-z' or a == '--zeromq' then
			options.codec = 'zeromq'
		elseif a == '-A' or a == '--adobe' then
			options.codec = 'adobe'
		else
			stderr('Unknown option: ' .. a)
			stderr(HELP)
			os.exit(2)
		end
		i = i + 1
	end
	return options
end

local function run_tests()
	local script = debug.getinfo(1, 'S').source:sub(2)
	local dir = script:match('^(.*)/[^/]+$') or '.'
	local name = script:match('([^/]+)$')
	local test_path = dir .. '/test/' .. name .. '_test'
	local ok = os.execute(test_path .. ' >/dev/null')
	os.exit(ok and 0 or 1)
end

local function main(argv)
	local options = parse_args(argv)
	if options.help then
		io.write(HELP)
		return
	end
	if options.about then
		io.write(ABOUT, '\n')
		return
	end
	if options.test then
		run_tests()
		return
	end

	local data = read_stdin()
	local mode = options.mode
	local codec_name = options.codec

	if not mode then
		local kind = classify(data)
		mode = (kind == 'binary') and 'encode' or 'decode'
		codec_name = codec_name or ((kind == 'binary') and 'zeromq' or kind)
	elseif not codec_name then
		if mode == 'encode' then
			codec_name = 'zeromq'
		else
			local kind = classify(data)
			codec_name = (kind == 'binary') and 'zeromq' or kind
		end
	end

	local codec = codec_name == 'adobe' and ADOBE or ZEROMQ
	local ok, result = pcall(mode == 'encode' and encode or decode, data, codec)
	if not ok then
		stderr(result)
		os.exit(1)
	end
	io.write(result)
end

main({ ... })
