#!/usr/bin/env bash

shopt -s extglob

remove_z_library_attrib() {
	local files=()

	# Use glob's null-separated output so filenames with spaces stay intact
	mapfile -d '' -t files < <(glob -0 '* @(\(Z-Library\)|\(z-library.sk, 1lib.sk, z-lib.sk\)).*')

	if [[ ${#files[@]} -eq 0 ]]; then
		return 0
	fi

	local file
	for file in "${files[@]}"; do
		mv -- "$file" "${file/ @(\(Z-Library\)|\(z-library.sk, 1lib.sk, z-lib.sk\))/}"
	done
}

# Run the function if this script is executed directly
if ! (return 0 2>/dev/null); then
	# Check if we are running tests
	if [ "$1" = "--test" ]; then
		# Run tests from the test file
		. "$HOME/dotfiles/bin/test/$(basename "${0##\-}")_test"
	else
		# If called directly, pass all arguments to the function
		$(basename "${0##\-}") "$@"
	fi
fi
