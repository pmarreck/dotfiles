#!/usr/bin/env bash
# jj-reattach-head — attach git's HEAD to the bookmark on jj's @-.
#
# Why: jj's working-copy-is-a-commit model parks @ on a fresh empty commit
# after every `jj commit`. That empty WC isn't on any bookmark, so the
# colocated git side ends up with .git/HEAD holding a raw SHA (detached
# state) — even though the bookmark ref (e.g. master / yolo) advanced to the
# right commit. Git refuses to auto-attach HEAD via SHA equality because
# that would silently mutate whichever branch happens to share the SHA, and
# the ambiguity isn't always resolvable (two bookmarks on the same commit).
# We solve it the way git insists: an explicit symbolic ref.
#
# Usage:
#   jj-reattach-head          # auto-detect; requires exactly 1 bookmark on @-
#   jj-reattach-head <name>   # explicit; bypasses the ambiguity check

set -u

usage() {
	cat <<'EOF' >&2
usage: jj-reattach-head [<bookmark>]
  Auto-detects the local bookmark on jj's @- and writes
  `ref: refs/heads/<bookmark>` to .git/HEAD.
  If more than one bookmark sits on @-, pass the one you want explicitly.
EOF
}

case "${1:-}" in
	-h|--help) usage; exit 0 ;;
esac

root=$(jj root 2>/dev/null) || {
	echo "jj-reattach-head: not inside a jj repo" >&2
	exit 1
}
gitdir="$root/.git"
[ -d "$gitdir" ] || {
	echo "jj-reattach-head: no .git/ at $gitdir (not a colocated repo?)" >&2
	exit 1
}

# Explicit override skips the auto-detection.
if [ "${1:-}" != "" ]; then
	bm="$1"
else
	# Bookmark names on @-, one per line, '*' pending-push marker stripped.
	# Empty lines filtered out.
	mapfile -t bms < <(
		jj log -r '@-' --no-graph -T 'bookmarks.map(|b| b.name() ++ "\n").join("")' 2>/dev/null \
			| sed 's/\*$//' \
			| grep -v '^$'
	)
	case "${#bms[@]}" in
		0)
			echo "jj-reattach-head: no local bookmark on @-; nothing to attach to" >&2
			echo "  hint: 'jj bookmark create <name> -r @-' first, or pass a bookmark explicitly" >&2
			exit 1
			;;
		1)
			bm="${bms[0]}"
			;;
		*)
			# Loud failure: list candidates so the user can pick.
			echo "jj-reattach-head: multiple bookmarks on @-: ${bms[*]}" >&2
			echo "  pass one explicitly: jj-reattach-head <bookmark>" >&2
			exit 1
			;;
	esac
fi

printf 'ref: refs/heads/%s\n' "$bm" > "$gitdir/HEAD"
echo "HEAD → refs/heads/$bm"
