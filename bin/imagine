#!/usr/bin/env bash

# Uses the OpenAI image generation API (gpt-image-1) to generate an image
# from a prompt and display it in the terminal via kitty graphics or sixel.
# Example usage: imagine a cow jumping over the moon
# Environment variables:
#   GEOMETRY   - Image size: 1024x1024 (default), 1536x1024, 1024x1536, or auto
#   QUALITY    - Image quality: low, medium, or high (default)
imagine() {
	[ -n "${EDIT}" ] && unset EDIT && edit_function "${FUNCNAME[0]}" "$BASH_SOURCE" && return
	needs magick Please install ImageCraptastick I mean ImageMagick
	needs jq "Please install jq"
	if ! check_kitty_support 2>/dev/null && ! check_sixel_support 2>/dev/null; then
		echo "Error: No supported graphics protocol detected (tried kitty and sixel)." >&2
		return 1
	fi
	if [[ -z "$OPENAI_API_KEY" ]]; then
		echo "Error: OPENAI_API_KEY is not set." >&2
		return 1
	fi
	local prompt size quality create_img stamp filename
	prompt="$*"
	if [[ -z "$prompt" ]]; then
		echo "Usage: imagine <prompt>" >&2
		echo "Example: imagine a cow jumping over the moon" >&2
		return 1
	fi
	size=${GEOMETRY:-1024x1024}
	quality=${QUALITY:-high}
	create_img=$(curl https://api.openai.com/v1/images/generations -s \
		-H "Content-Type: application/json" \
		-H "Authorization: Bearer $OPENAI_API_KEY" \
		-d "$(jq -n \
			--arg prompt "$prompt" \
			--arg size "$size" \
			--arg quality "$quality" \
			'{model: "gpt-image-1", prompt: $prompt, n: 1, size: $size, quality: $quality}')"
	)
	if echo "$create_img" | jq -e '.error' >/dev/null 2>&1; then
		echo -n "Error: " >&2
		echo "$create_img" | jq -r '.error.message' >&2
		return 1
	fi
	(( DEBUG )) && echo "$create_img" | jq '(.data[0].b64_json |= "...[truncated]...")' >&2
	stamp=$(DATETIMESTAMPFORMAT="+%Y%m%d%H%M%S%N" datetimestamp)
	filename=$(gmktemp -t "img-${stamp}-XXXX" --suffix .png)
	echo "$create_img" | jq -r '.data[0].b64_json' | base64 -d > "$filename"
	if [[ ! -s "$filename" ]]; then
		echo "Error: Failed to decode image data." >&2
		return 1
	fi
	display_image "$filename"
	echo "This image is currently stored temporarily at: $filename" >&2
}

# Run the function if this script is executed directly
if ! (return 0 2>/dev/null); then
	# Check if we are running tests
	if [ "$1" = "--test" ]; then
		# Run tests from the test file
		. "$HOME/dotfiles/bin/test/$(basename "${0##\-}")_test"
	else
		# If called directly, pass all arguments to the function
		$(basename "${0##\-}") "$@"
	fi
fi
