#!/usr/bin/env bash
# mlx-server — Manage the gemma4-heretical MLX inference server (launchd)
#
# Usage:
#   mlx-server start     Start the server (launchd)
#   mlx-server stop      Stop the server
#   mlx-server restart   Restart the server
#   mlx-server status    Show server status
#   mlx-server log       Tail the server log
#   mlx-server test      Quick connectivity test
#   mlx-server update    Update mlx-vlm, then restart

LABEL="ai.gemma4-heretical.mlx-server"
PLIST="$HOME/Library/LaunchAgents/${LABEL}.plist"
LOG="$HOME/.openclaw/mlx-server.log"
PORT="${MLX_SERVER_PORT:-8080}"

case "${1:-status}" in
	start)
		launchctl load -w "$PLIST" 2>/dev/null
		launchctl start "$LABEL" 2>/dev/null
		echo "Started ${LABEL}"
		echo "Server will be available at http://127.0.0.1:${PORT}/v1"
		echo "Note: first start may take a minute (nix develop + model load)"
		;;
	stop)
		launchctl stop "$LABEL" 2>/dev/null
		launchctl unload "$PLIST" 2>/dev/null
		echo "Stopped ${LABEL}"
		;;
	restart)
		launchctl stop "$LABEL" 2>/dev/null
		sleep 2
		launchctl start "$LABEL" 2>/dev/null
		echo "Restarted ${LABEL}"
		;;
	status)
		if launchctl list "$LABEL" >/dev/null 2>&1; then
			PID=$(launchctl list "$LABEL" 2>/dev/null | grep PID | awk '{print $NF}')
			echo "Running (PID: ${PID:-unknown})"
			echo "Port: ${PORT}"
			curl -s "http://127.0.0.1:${PORT}/v1/models" 2>/dev/null && echo "" || echo "Server not yet responding (may still be loading)"
		else
			echo "Not running"
		fi
		;;
	log)
		if [ -f "$LOG" ]; then
			tail -f "$LOG"
		else
			echo "No log file yet at ${LOG}"
		fi
		;;
	test)
		echo "Testing http://127.0.0.1:${PORT}/v1/models ..."
		curl -s "http://127.0.0.1:${PORT}/v1/models" | python3 -m json.tool 2>/dev/null || echo "Server not responding"
		;;
	update)
		echo "Updating mlx-vlm..."
		cd "$HOME/Documents-CloudManaged/gemma4-heretical" || exit 1
		nix develop -c bash -c 'source .venv/bin/activate && pip install -U mlx-vlm 2>&1' | tail -5
		echo "Restarting server..."
		launchctl stop "$LABEL" 2>/dev/null
		sleep 2
		launchctl start "$LABEL" 2>/dev/null
		echo "Done"
		;;
	*)
		echo "Usage: mlx-server {start|stop|restart|status|log|test|update}"
		exit 1
		;;
esac
