#!/usr/bin/env bash

# Reattach a detached Git HEAD to <branchname>, pointing that branch at the
# currently checked-out commit. Uses git branch -f + symbolic-ref rather than
# checkout, so the worktree and index are never touched and uncommitted changes
# are safe. Refuses to act if HEAD is attached to a different branch, and never
# creates branches (a typo guard).
realign_HEAD() {
	local branch="${1:-}"
	case "$branch" in
		-h|--help)
			echo "usage: realign_HEAD <branchname>  # reattach detached git HEAD to <branchname> at the current commit"
			echo "Use this to safely reattach a deliberately detached Git HEAD."
			echo "Never touches worktree/index (branch -f + symbolic-ref). Refuses if HEAD is on another branch."
			return 0
			;;
	esac
	if [ -z "$branch" ]; then
		echo "usage: realign_HEAD <branchname>" >&2
		return 64
	fi
	if ! git rev-parse --git-dir >/dev/null 2>&1; then
		echo "realign_HEAD: not inside a git repository" >&2
		return 1
	fi
	local current
	if current=$(git symbolic-ref -q --short HEAD); then
		if [ "$current" = "$branch" ]; then
			echo "HEAD already attached to '$branch' at $(git rev-parse --short HEAD); nothing to do."
			return 0
		fi
		echo "realign_HEAD: HEAD is attached to branch '$current', not detached; refusing to move '$branch'." >&2
		return 1
	fi
	if ! git show-ref --verify -q "refs/heads/$branch"; then
		echo "realign_HEAD: no local branch '$branch' (refusing to create one)" >&2
		return 1
	fi
	local sha
	sha=$(git rev-parse HEAD) || return 1
	git branch -f "$branch" "$sha" || return 1
	git symbolic-ref HEAD "refs/heads/$branch" || return 1
	echo "Realigned: '$branch' -> ${sha:0:12}, HEAD attached to '$branch'."
}

# Run the function if this script is executed directly
if ! (return 0 2>/dev/null); then
	# Check if we are running tests
	if [ "$1" = "--test" ]; then
		# Run tests from the test file
		_test_file="$HOME/dotfiles/bin/test/$(basename "${0##\-}")_test"
		if [ -f "$_test_file" ]; then . "$_test_file" > /dev/null; fi
	else
		# If called directly, pass all arguments to the function
		$(basename "${0##\-}") "$@"
	fi
fi
