#!/usr/bin/env bash

_assert_show_help() {
	cat <<'EOF'
Usage: assert VALUE1 OPERATOR VALUE2 [MESSAGE]

Compare two values and return 0 when the assertion passes or 1 when it fails.
Malformed invocations return 2.

Operators:
	=, ==       Values are equal
	!=, !==     Values are not equal
	=~          VALUE1 matches the Bash extended regular expression VALUE2
	!=~, !~     VALUE1 does not match VALUE2

Options:
	-h, --help  Show this help message
	--test      Run associated tests (when assert is executed, not sourced)
EOF
}

assert() {
	if [[ -n "${EDIT:-}" ]]; then
		unset EDIT
		edit_function "${FUNCNAME[0]}" "$BASH_SOURCE"
		return
	fi

	if (( $# == 1 )) && [[ "$1" == '-h' || "$1" == '--help' ]]; then
		_assert_show_help
		return 0
	fi

	if (( $# < 3 || $# > 4 )); then
		printf 'Error: assert expects 3 or 4 arguments; received %s.\n' "$#" >&2
		_assert_show_help >&2
		return 2
	fi

	local arg1="$1"
	local comp="$2"
	local arg2="$3"
	local message="${4:-}"
	local passed=false

	case "$comp" in
		'=' | '==')
			[[ "$arg1" == "$arg2" ]] && passed=true
			;;
		'!=' | '!==')
			[[ "$arg1" != "$arg2" ]] && passed=true
			;;
		'=~')
			[[ "$arg1" =~ $arg2 ]] && passed=true
			;;
		'!=~' | '!~')
			[[ ! "$arg1" =~ $arg2 ]] && passed=true
			;;
		*)
			printf 'Error: unknown comparison operator: %s\n' "$comp" >&2
			_assert_show_help >&2
			return 2
			;;
	esac

	if "$passed"; then
		return 0
	fi

	local caller="${BASH_SOURCE[1]:-${BASH_SOURCE[0]}}"
	local actualfile
	local linenum="${BASH_LINENO[0]:-?}"
	actualfile=$(readlink -f "$caller" 2>/dev/null) || actualfile="$caller"
	printf 'Assertion failed: %q %s %q @ %s:%s\n' \
		"$arg1" "$comp" "$arg2" "$actualfile" "$linenum" >&2
	[[ -n "$message" ]] && printf '%s\n' "$message" >&2
	return 1
}

if ! (return 0 2>/dev/null); then
	if [[ "${1:-}" == '--test' ]]; then
		if (( $# != 1 )); then
			printf 'Error: --test does not accept arguments.\n' >&2
			exit 2
		fi
		test_file="$(dirname "${BASH_SOURCE[0]}")/test/assert_test"
		if [[ ! -x "$test_file" ]]; then
			printf 'Error: test file is missing or not executable: %s\n' "$test_file" >&2
			exit 1
		fi
		"$test_file" >/dev/null
		exit $?
	fi
	assert "$@"
	exit $?
fi
