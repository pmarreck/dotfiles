#!/usr/bin/env bash

# Test the erect-agent-stack function
erect_agent_stack_test() {
  local fails=0 out status sock="erect_test_$$"
  local tmproot; tmproot=$(mktemp -d --tmpdir erect_agent_stack_test.XXXXXX)
  tmproot=$(cd "$tmproot" && pwd -P)
  mkdir -p "$tmproot/projalpha"
  mkdir -p "$tmproot/projbeta"
  mkdir -p "$tmproot/projgamma"
  mkdir -p "$tmproot/projdelta"
  _t() { tmux -L "$sock" "$@"; }
  _t kill-server 2>/dev/null

  # --help exits 0 with usage
  out=$(erect-agent-stack --help); status=$?
  assert "$status" == "0" "--help exits 0"
  ((fails+=$?))
  assert "$out" =~ "usage" "--help prints usage"
  ((fails+=$?))

  # no args -> usage error 64
  ERECT_TMUX_SOCKET="$sock" erect-agent-stack >/dev/null 2>&1; status=$?
  assert "$status" == "64" "no args exits 64"
  ((fails+=$?))

  # missing project dir -> 66 (EX_NOINPUT)
  ERECT_TMUX_SOCKET="$sock" erect-agent-stack "$tmproot/nope" >/dev/null 2>&1; status=$?
  assert "$status" == "66" "missing project dir exits 66"
  ((fails+=$?))

  # CREATE branch: no session yet -> creates detached session, dry-launches claude
  out=$(ERECT_TMUX_SOCKET="$sock" ERECT_DRY_RUN=1 erect-agent-stack "$tmproot/projalpha" 2>&1); status=$?
  assert "$status" == "0" "create branch exits 0"
  ((fails+=$?))
  assert "$out" =~ "created" "reports created outcome"
  ((fails+=$?))
  assert "$out" =~ "claude --rc --permission-mode bypassPermissions --name projalpha --continue" \
    "dry-run resumes the most recent conversation in the project directory"
  ((fails+=$?))
  assert "$(_t list-sessions -F '#S' 2>/dev/null | grep -cx projalpha)" == "1" "tmux session exists"
  ((fails+=$?))
  assert "$(_t display-message -pt projalpha '#{pane_current_path}')" == "$tmproot/projalpha" "session cwd = project dir"
  ((fails+=$?))

  # --fresh omits --continue
  out=$(ERECT_TMUX_SOCKET="$sock" ERECT_DRY_RUN=1 erect-agent-stack --fresh "$tmproot/projalpha" 2>&1)
  assert "$out" !=~ "--continue" "--fresh omits continue flag"
  ((fails+=$?))

  # JOINED-LAUNCHED branch: session exists, no agent marker -> no dup session
  out=$(ERECT_TMUX_SOCKET="$sock" ERECT_DRY_RUN=1 erect-agent-stack "$tmproot/projalpha" 2>&1)
  assert "$out" =~ "joined-launched" "existing agentless session reports joined-launched"
  ((fails+=$?))
  assert "$(_t list-sessions -F '#S' | grep -cx projalpha)" == "1" "no duplicate session created"
  ((fails+=$?))

  # JOINED-RUNNING branch: simulate a running Claude via its footer marker
  _t send-keys -t projalpha "echo 'esc to interrupt'; tmux -L $sock wait-for -S marker_done" Enter
  _t wait-for marker_done
  out=$(ERECT_TMUX_SOCKET="$sock" ERECT_DRY_RUN=1 erect-agent-stack "$tmproot/projalpha" 2>&1)
  assert "$out" =~ "joined-running" "session with agent marker reports joined-running"
  ((fails+=$?))
  assert "$out" !=~ "launch:" "joined-running must not launch anything"
  ((fails+=$?))

  # --ping delivered (dry) on a running agent
  out=$(ERECT_TMUX_SOCKET="$sock" ERECT_DRY_RUN=1 erect-agent-stack --ping "hello agent" "$tmproot/projalpha" 2>&1)
  assert "$out" =~ "ping: hello agent" "dry-run reports the ping payload"
  ((fails+=$?))


  # --- backend broadening (--agent / --checker / env-gating) ---
  out=$(ERECT_TMUX_SOCKET="$sock" ERECT_DRY_RUN=1 erect-agent-stack --fresh --agent codex "$tmproot/projbeta" 2>&1)
  assert "$out" =~ "launch: codex --dangerously-bypass-approvals-and-sandbox" "codex fresh uses danger flag"
  ((fails+=$?))
  [[ "$out" == *"projects.\\\"$tmproot/projbeta\\\".trust_level=\\\"trusted\\\""* ]]; status=$?
  assert "$status" == "0" "Codex launch explicitly trusts the canonical project path"
  ((fails+=$?))
  out=$(ERECT_TMUX_SOCKET="$sock" ERECT_DRY_RUN=1 erect-agent-stack --agent codex "$tmproot/projbeta" 2>&1)
  assert "$out" =~ "launch: codex resume --last --dangerously-bypass-approvals-and-sandbox" "codex resume uses resume subcommand"
  ((fails+=$?))

  out=$(ERECT_TMUX_SOCKET="$sock" ERECT_DRY_RUN=1 erect-agent-stack --fresh --agent gemini "$tmproot/projbeta" 2>&1)
  assert "$out" =~ "launch: gemini --yolo" "gemini fresh uses --yolo"
  ((fails+=$?))

  out=$(ERECT_TMUX_SOCKET="$sock" ERECT_DRY_RUN=1 erect-agent-stack --fresh -a gemini "$tmproot/projbeta" 2>&1)
  assert "$out" =~ "launch: gemini --yolo" "-a aliases --agent"
  ((fails+=$?))

  out=$(ERECT_TMUX_SOCKET="$sock" ERECT_DRY_RUN=1 erect-agent-stack --fresh "$tmproot/projbeta" 2>&1)
  assert "$out" =~ "launch: claude --rc" "default agent stays claude"
  ((fails+=$?))

  ERECT_TMUX_SOCKET="$sock" erect-agent-stack --agent bogus "$tmproot/projbeta" >/dev/null 2>&1; status=$?
  assert "$status" == "64" "unknown agent exits 64"
  ((fails+=$?))

  ERECT_TMUX_SOCKET="$sock" GEMINI_API_KEY= erect-agent-stack --agent gemini "$tmproot/projbeta" >/dev/null 2>&1; status=$?
  assert "$status" == "78" "gated agent without its env exits 78"
  ((fails+=$?))

  out=$(ERECT_TMUX_SOCKET="$sock" ERECT_DRY_RUN=1 erect-agent-stack --fresh --checker "$tmproot/projbeta" 2>&1)
  assert "$out" =~ "launch: MFIC_ROLE=checker claude" "--checker prepends MFIC_ROLE=checker"
  ((fails+=$?))

  # Codex's first-run trust gate is accepted once, then its own chrome—not
  # Claude's readiness markers—satisfies the boot gate.
  _t set-environment -g PATH "$HOME/dotfiles/bin/test/fixtures/erect-agent-stack:$PATH"
  _t set-environment -g ERECT_TMUX_SOCKET "$sock"
  _t set-option -g default-command \
    "exec env PATH='$HOME/dotfiles/bin/test/fixtures/erect-agent-stack:$PATH' bash --noprofile --norc"
  out=$(PATH="$HOME/dotfiles/bin/test/fixtures/erect-agent-stack:$PATH" \
    OPENAI_API_KEY=test ERECT_TMUX_SOCKET="$sock" ERECT_BOOT_TIMEOUT=5 \
    erect-agent-stack --fresh --agent codex --no-attach "$tmproot/projgamma" 2>&1)
  status=$?
  assert "$status" == "0" "Codex chrome satisfies the boot-readiness gate"
  ((fails+=$?))
  _t wait-for -S fake_codex_stop

  # A resumed Codex pane may be filled by prior conversation, but its persistent
  # footer is definitive without confusing a foreground trust gate for readiness.
  (
    . "$HOME/dotfiles/bin/erect-agent-stack"
    _eas_tmux() {
      case "$1" in
        capture-pane) printf 'prior conversation without startup header\n95%% context left\n' ;;
        display-message) printf 'codex\n' ;;
      esac
    }
    ERECT_BOOT_TIMEOUT=1 _eas_bootwait resumed-codex codex
  )
  status=$?
  assert "$status" == "0" "Codex persistent chrome satisfies resumed-session readiness"
  ((fails+=$?))

  # Codex's paste-burst protection needs an explicit bracketed paste boundary;
  # the following plain Enter must remain a distinct submit key.
  local capture="$tmproot/codex-ping.bin"
  local ready="codex_reader_ready_$$" done="codex_reader_done_$$"
  local reader
  reader="stty raw -echo; printf '\\033[?2004hesc to interrupt\\r\\n'; tmux -L '$sock' wait-for -S '$ready'; IFS= read -r -d '|' data; printf '%s' \"\$data\" > '$capture'; tmux -L '$sock' wait-for -S '$done'; stty sane"
  _t new-session -d -s projdelta -c "$tmproot/projdelta"
  _t send-keys -t projdelta "$reader" Enter
  _t wait-for "$ready"
  out=$(OPENAI_API_KEY=test ERECT_TMUX_SOCKET="$sock" \
    erect-agent-stack --agent codex --ping "hello codex" --no-attach "$tmproot/projdelta" 2>&1)
  status=$?
  _t send-keys -t projdelta -l '|'
  _t wait-for "$done"
  local ping_hex
  ping_hex=$(od -An -tx1 -v "$capture" | tr -d ' \n')
  assert "$status" == "0" "Codex ping delivery exits 0"
  ((fails+=$?))
  assert "$ping_hex" == "1b5b3230307e68656c6c6f20636f6465781b5b3230317e0a" \
    "Codex ping is bracketed paste followed by plain Enter"
  ((fails+=$?))
  _t kill-server 2>/dev/null
  rm -rf "$tmproot"
  return "$fails"
}

erect_agent_stack_test
