#!/usr/bin/env bash
# Tests for git-fsck-all
# Exit code == number of failing tests.

make_repo() {
	local dir="$1"
	mkdir -p "$dir"
	(
		cd "$dir" && \
		git init -q -b main && \
		echo hello > a && \
		git add a && \
		git -c user.email=t@t -c user.name=t commit -q -m init
	)
}

corrupt_repo() {
	local dir="$1" obj
	obj=$(find "$dir/.git/objects" -type f ! -path '*/pack/*' 2>/dev/null | head -n1)
	[ -z "$obj" ] && return 1
	chmod +w "$obj"
	printf "corruption\n" > "$obj"
}

make_dsstore_repo() {
	local dir="$1"
	make_repo "$dir"
	touch "$dir/.git/refs/.DS_Store"
}

# Craft a repo whose HEAD points to a tree with two exact-duplicate entries.
make_exact_dup_repo() {
	local dir="$1" blob bin tree commit
	make_repo "$dir"
	blob=$(printf 'hi\n' | git -C "$dir" hash-object -w --stdin)
	bin=$(printf '%s' "$blob" | xxd -r -p)
	tree=$( { printf '100644 dup\0'; printf '%s' "$bin"; printf '100644 dup\0'; printf '%s' "$bin"; } | git -C "$dir" hash-object -w -t tree --stdin --literally )
	commit=$(git -C "$dir" commit-tree "$tree" -m 'dup')
	git -C "$dir" update-ref refs/heads/main "$commit"
}

GFA="$HOME/dotfiles/bin/git-fsck-all"

FIXT=$(mktemp -d --tmpdir gitfsckall_test.XXXXXX)
EMPTY=$(mktemp -d --tmpdir gitfsckall_empty.XXXXXX)
ALLGOOD=$(mktemp -d --tmpdir gitfsckall_allgood.XXXXXX)
FILTERED=$(mktemp -d --tmpdir gitfsckall_filtered.XXXXXX)
DUPF=$(mktemp -d --tmpdir gitfsckall_dup.XXXXXX)
trap 'chmod -R +w "$FIXT" "$EMPTY" "$ALLGOOD" "$FILTERED" "$DUPF" 2>/dev/null; rm -rf "$FIXT" "$EMPTY" "$ALLGOOD" "$FILTERED" "$DUPF"' EXIT

make_repo "$FIXT/good" >/dev/null 2>&1
make_repo "$FIXT/bad"  >/dev/null 2>&1
corrupt_repo "$FIXT/bad"

make_repo "$ALLGOOD/r1" >/dev/null 2>&1
make_repo "$ALLGOOD/r2" >/dev/null 2>&1

# Repo set that exercises the remaining safe-litter filter.
make_dsstore_repo "$FILTERED/ds" >/dev/null 2>&1

make_exact_dup_repo "$DUPF/dup" >/dev/null 2>&1

fails=0
tests=0

# Test 1: --help exits 0 and prints usage
((tests++))
echo "Testing: --help prints usage and exits 0..."
if out=$("$GFA" --help 2>&1) && [[ "$out" == *"Usage:"* ]]; then
	echo "✓ Test passed: --help works"
else
	echo "✗ Test failed: --help output did not match or exit nonzero" >&2
	echo "  Output: $out" >&2
	((fails++))
fi

# Test 2: exit code equals number of failed repos (1 bad)
((tests++))
echo "Testing: exit code equals number of failed repos..."
"$GFA" "$FIXT" >/dev/null 2>/dev/null
rc=$?
if [[ $rc -eq 1 ]]; then
	echo "✓ Test passed: exit code is 1 for one failing repo"
else
	echo "✗ Test failed: expected exit 1, got $rc" >&2
	((fails++))
fi

# Test 3: stdout report includes pass/fail counts and the failed repo path
((tests++))
echo "Testing: stdout report includes counts and failed repo path..."
stdout=$("$GFA" "$FIXT" 2>/dev/null)
if [[ "$stdout" == *"1 passed"* ]] && \
   [[ "$stdout" == *"1 failed"* ]] && \
   [[ "$stdout" == *"$FIXT/bad"* ]]; then
	echo "✓ Test passed: report contains expected fields"
else
	echo "✗ Test failed: report missing expected fields" >&2
	echo "  Stdout: $stdout" >&2
	((fails++))
fi

# Test 4: progress lines go to stderr, report to stdout
((tests++))
echo "Testing: progress -> stderr, report -> stdout..."
stdout=$("$GFA" "$FIXT" 2>/dev/null)
stderr=$("$GFA" "$FIXT" 2>&1 >/dev/null)
if [[ "$stdout" != *"Discovering"* ]] && \
   [[ "$stdout" != *"Validating"* ]] && \
   [[ "$stderr" == *"Discovered"* ]]; then
	echo "✓ Test passed: streams separated correctly"
else
	echo "✗ Test failed: progress/report stream split incorrect" >&2
	echo "  Stdout: $stdout" >&2
	echo "  Stderr: $stderr" >&2
	((fails++))
fi

# Test 5: empty dir reports no repos and exits 0
((tests++))
echo "Testing: empty dir exits 0 with no-repos message..."
out=$("$GFA" "$EMPTY" 2>/dev/null)
rc=$?
if [[ $rc -eq 0 ]] && [[ "$out" == *"No git repositories found"* ]]; then
	echo "✓ Test passed: empty dir handled"
else
	echo "✗ Test failed: rc=$rc, output=$out" >&2
	((fails++))
fi

# Test 6: all-healthy repos pass with exit 0
((tests++))
echo "Testing: all-healthy repos exit 0 with N passed..."
out=$("$GFA" "$ALLGOOD" 2>/dev/null)
rc=$?
if [[ $rc -eq 0 ]] && [[ "$out" == *"2 passed"* ]] && [[ "$out" == *"0 failed"* ]]; then
	echo "✓ Test passed: all-healthy case reported correctly"
else
	echo "✗ Test failed: rc=$rc output=$out" >&2
	((fails++))
fi

# Test 7: failed repo output includes fsck error details
((tests++))
echo "Testing: failed-repo report includes fsck error details..."
out=$("$GFA" "$FIXT" 2>/dev/null)
if [[ "$out" == *"error"* ]] || [[ "$out" == *"fatal"* ]] || [[ "$out" == *"corrupt"* ]]; then
	echo "✓ Test passed: fsck error text surfaced"
else
	echo "✗ Test failed: no fsck error text in report" >&2
	echo "  Output: $out" >&2
	((fails++))
fi

# Test 8: .DS_Store-only fixture exits 0 (safe litter is filtered)
((tests++))
echo "Testing: .DS_Store-only fixture exits 0..."
"$GFA" "$FILTERED" >/dev/null 2>/dev/null
rc=$?
if [[ $rc -eq 0 ]]; then
	echo "✓ Test passed: filtered-only fixture exits 0"
else
	echo "✗ Test failed: expected exit 0, got $rc" >&2
	((fails++))
fi

# Test 9: filtered fixture reports .DS_Store to stderr as fixable
((tests++))
echo "Testing: .DS_Store lands in the fixable section on stderr..."
stderr=$("$GFA" "$FILTERED" 2>&1 >/dev/null)
if [[ "$stderr" == *"Fixable"* ]] && [[ "$stderr" == *".DS_Store"* ]]; then
	echo "✓ Test passed: .DS_Store reported to stderr as fixable"
else
	echo "✗ Test failed: expected fixable section with .DS_Store" >&2
	echo "  Stderr: $stderr" >&2
	((fails++))
fi

# Test 10: triage --dry-run shows plan without deleting
((tests++))
echo "Testing: triage --dry-run lists plan but deletes nothing..."
DRYRUN=$(mktemp -d --tmpdir gitfsckall_dryrun.XXXXXX)
make_dsstore_repo "$DRYRUN/ds" >/dev/null 2>&1
ds_file="$DRYRUN/ds/.git/refs/.DS_Store"
out=$("$GFA" triage --dry-run "$DRYRUN" 2>/dev/null)
if [[ "$out" == *"Triage plan"* ]] && [[ "$out" == *"Dry-run"* ]] && [ -e "$ds_file" ]; then
	echo "✓ Test passed: dry-run preserved the file"
else
	echo "✗ Test failed: dry-run did not behave as expected" >&2
	echo "  out=$out file-exists=$([ -e "$ds_file" ] && echo yes || echo no)" >&2
	((fails++))
fi
rm -rf "$DRYRUN"

# Test 11: triage --yes removes .DS_Store files
((tests++))
echo "Testing: triage --yes actually removes fixable files..."
DOIT=$(mktemp -d --tmpdir gitfsckall_doit.XXXXXX)
make_dsstore_repo "$DOIT/ds" >/dev/null 2>&1
ds_file="$DOIT/ds/.git/refs/.DS_Store"
"$GFA" triage --yes "$DOIT" >/dev/null 2>&1
if [ ! -e "$ds_file" ]; then
	echo "✓ Test passed: fixable files removed"
else
	echo "✗ Test failed: files still present after triage --yes" >&2
	echo "  ds exists: $([ -e "$ds_file" ] && echo yes || echo no)" >&2
	((fails++))
fi
rm -rf "$DOIT"

# Test 12: triage in non-interactive mode without --yes aborts
((tests++))
echo "Testing: triage non-interactive without --yes aborts..."
NOTTY=$(mktemp -d --tmpdir gitfsckall_notty.XXXXXX)
make_dsstore_repo "$NOTTY/ds" >/dev/null 2>&1
ds_file="$NOTTY/ds/.git/refs/.DS_Store"
# stdin is already piped (here-string) so not a tty; expect abort and preserved file
"$GFA" triage "$NOTTY" </dev/null >/dev/null 2>&1
rc=$?
if [[ $rc -ne 0 ]] && [ -e "$ds_file" ]; then
	echo "✓ Test passed: non-interactive triage aborted, file preserved"
else
	echo "✗ Test failed: expected abort+preserve, got rc=$rc file=$([ -e "$ds_file" ] && echo yes || echo no)" >&2
	((fails++))
fi
rm -rf "$NOTTY"

# Test 13: duplicate-entries: script surfaces conflicting filenames
((tests++))
echo "Testing: duplicateEntries output lists conflicting filenames..."
out=$("$GFA" "$DUPF" 2>/dev/null)
if [[ "$out" == *"duplicateEntries"* ]] && [[ "$out" == *"dup: dup, dup"* ]]; then
	echo "✓ Test passed: conflicting filenames surfaced"
else
	echo "✗ Test failed: missing filename annotation" >&2
	echo "  Output: $out" >&2
	((fails++))
fi

# Summary
if [[ $fails -eq 0 ]]; then
	echo "All $tests tests passed"
else
	echo "$fails of $tests tests failed" >&2
fi
exit $fails
