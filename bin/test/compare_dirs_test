#!/usr/bin/env bash

test_compare_dirs() {
	local fails=0
	local tests=0

	echo "Testing compare-dirs..."

	# Test 1: --help flag
	(( tests++ ))
	local help_output
	help_output=$(compare-dirs --help 2>&1)
	local exit_code=$?
	if [ "$exit_code" -eq 0 ] && [[ "$help_output" == *"Usage:"* ]]; then
		echo "âś“ --help prints usage and exits 0"
	else
		echo "âś— --help failed: exit=$exit_code output='$help_output'" >&2
		(( fails++ ))
	fi

	# Test 2: -h flag (alias)
	(( tests++ ))
	help_output=$(compare-dirs -h 2>&1)
	exit_code=$?
	if [ "$exit_code" -eq 0 ] && [[ "$help_output" == *"Usage:"* ]]; then
		echo "âś“ -h prints usage and exits 0"
	else
		echo "âś— -h failed: exit=$exit_code" >&2
		(( fails++ ))
	fi

	# Test 3: --about flag
	(( tests++ ))
	local about_output
	about_output=$(compare-dirs --about 2>&1)
	exit_code=$?
	if [ "$exit_code" -eq 0 ] && [ -n "$about_output" ]; then
		echo "âś“ --about prints description and exits 0"
	else
		echo "âś— --about failed: exit=$exit_code" >&2
		(( fails++ ))
	fi

	# Test 4: no arguments exits with error
	(( tests++ ))
	compare-dirs >/dev/null 2>&1
	exit_code=$?
	if [ "$exit_code" -eq 2 ]; then
		echo "âś“ no arguments exits 2"
	else
		echo "âś— no arguments: expected exit 2, got $exit_code" >&2
		(( fails++ ))
	fi

	# Test 5: nonexistent directory exits with error
	(( tests++ ))
	compare-dirs /nonexistent/path/aaa /nonexistent/path/bbb >/dev/null 2>&1
	exit_code=$?
	if [ "$exit_code" -eq 2 ]; then
		echo "âś“ nonexistent dirs exit 2"
	else
		echo "âś— nonexistent dirs: expected exit 2, got $exit_code" >&2
		(( fails++ ))
	fi

	# Test 6: identical empty directories â†’ exit 0, no output
	(( tests++ ))
	local tmpdir
	tmpdir=$(mktemp -d "${TMPDIR:-/tmp}/compare_dirs_test.XXXXXX")
	mkdir -p "$tmpdir/a" "$tmpdir/b"
	local output
	output=$(compare-dirs "$tmpdir/a" "$tmpdir/b" 2>&1)
	exit_code=$?
	if [ "$exit_code" -eq 0 ] && [ -z "$output" ]; then
		echo "âś“ identical empty dirs: exit 0, no output"
	else
		echo "âś— identical empty dirs: exit=$exit_code output='$output'" >&2
		(( fails++ ))
	fi
	rm -rf "$tmpdir"

	# Test 7: identical directories with files â†’ exit 0, no output
	(( tests++ ))
	tmpdir=$(mktemp -d "${TMPDIR:-/tmp}/compare_dirs_test.XXXXXX")
	mkdir -p "$tmpdir/a/sub" "$tmpdir/b/sub"
	echo "hello" > "$tmpdir/a/file.txt"
	echo "hello" > "$tmpdir/b/file.txt"
	echo "world" > "$tmpdir/a/sub/nested.txt"
	echo "world" > "$tmpdir/b/sub/nested.txt"
	# Match mtimes so metadata is identical
	touch -r "$tmpdir/a/file.txt" "$tmpdir/b/file.txt"
	touch -r "$tmpdir/a/sub/nested.txt" "$tmpdir/b/sub/nested.txt"
	touch -r "$tmpdir/a/sub" "$tmpdir/b/sub"
	output=$(compare-dirs "$tmpdir/a" "$tmpdir/b" 2>&1)
	exit_code=$?
	if [ "$exit_code" -eq 0 ] && [ -z "$output" ]; then
		echo "âś“ identical dirs with files: exit 0, no output"
	else
		echo "âś— identical dirs with files: exit=$exit_code output='$output'" >&2
		(( fails++ ))
	fi
	rm -rf "$tmpdir"

	# Test 8: content differences detected
	(( tests++ ))
	tmpdir=$(mktemp -d "${TMPDIR:-/tmp}/compare_dirs_test.XXXXXX")
	mkdir -p "$tmpdir/a" "$tmpdir/b"
	echo "hello" > "$tmpdir/a/file.txt"
	echo "world" > "$tmpdir/b/file.txt"
	touch -r "$tmpdir/a/file.txt" "$tmpdir/b/file.txt"
	output=$(compare-dirs "$tmpdir/a" "$tmpdir/b" 2>&1)
	exit_code=$?
	if [ "$exit_code" -eq 1 ] && [[ "$output" == *"content"* ]] && [[ "$output" == *"file.txt"* ]]; then
		echo "âś“ content difference detected"
	else
		echo "âś— content difference: exit=$exit_code output='$output'" >&2
		(( fails++ ))
	fi
	rm -rf "$tmpdir"

	# Summary
	if [ $fails -gt 0 ]; then
		echo ""
		echo "compare_dirs test FAILED: $fails of $tests tests failed" >&2
	else
		echo ""
		echo "compare_dirs test PASSED: All $tests tests passed"
	fi
	return $fails
}

# Run if executed directly
if ! (return 0 2>/dev/null); then
	test_compare_dirs
	exit $?
fi
