#!/usr/bin/env bash

# Tests for bin/date wrapper. See bin/test/tac_test for the full design rationale.
# Bug being prevented: whichdate=date (literal name) → $whichdate resolves
# through PATH and finds the wrapper itself → infinite recursion.

fails=0
tests=0

WRAPPER="$HOME/dotfiles/bin/date"
WRAPPER_CANONICAL="$(readlink -f "$WRAPPER")"
WRAPPER_DIR="$(dirname "$WRAPPER_CANONICAL")"
BASH_BIN="$(type -P bash)"
TIMEOUT_BIN="$(type -P timeout)"
SUPPORT_DIR=$(mktemp -d --tmpdir date_test_support.XXXXXX)
trap 'rm -rf "$SUPPORT_DIR"' EXIT
for support_command in bash basename grep readlink; do
	ln -s "$(type -P "$support_command")" "$SUPPORT_DIR/$support_command"
done
RESTRICTED_PATH="$WRAPPER_DIR:$SUPPORT_DIR:/bin:/usr/bin"

# Test 1: PATH puts wrapper first AND has no gdate. Wrapper must not recurse.
# Both macOS (/bin/date BSD) and Linux (/bin/date GNU) have a system date,
# so the wrapper-with-fix should find the non-wrapper and use it. Pre-fix
# wrapper would recurse on `whichdate=date` falling through to the wrapper.
((tests++))
echo "Testing: wrapper does not recurse when only itself is the first date..."
output=$(PATH="$RESTRICTED_PATH" "$TIMEOUT_BIN" 3 "$BASH_BIN" "$WRAPPER" '+%Y' 2>/dev/null)
rc=$?
if [[ $rc -eq 124 ]]; then
	echo "✗ Test failed: hit 3s timeout — wrapper is recursing into itself" >&2
	((fails++))
elif [[ $rc -eq 0 ]] && [[ "$output" =~ ^[0-9]{4}$ ]]; then
	echo "✓ Test passed: rc=0, output is a 4-digit year ('$output')"
elif [[ $rc -eq 1 ]]; then
	echo "✓ Test passed: clean error (rc=1, no real date reachable)"
else
	echo "✗ Test failed: rc=$rc output='$output'" >&2
	((fails++))
fi

# Test 2: wrapper-dir + a real date dir (no gdate) → uses real date.
((tests++))
echo "Testing: wrapper falls back to a real date when gdate is unavailable..."
REAL_DATE=""
while IFS= read -r candidate; do
	[[ -z "$candidate" ]] && continue
	canon="$(readlink -f "$candidate" 2>/dev/null)"
	if [[ "$canon" != "$WRAPPER_CANONICAL" ]]; then
		REAL_DATE="$candidate"
		break
	fi
done < <(type -aP date 2>/dev/null)

if [[ -z "$REAL_DATE" ]]; then
	echo "✓ Test skipped: no non-wrapper date on this system"
else
	REAL_DATE_DIR="$(dirname "$REAL_DATE")"
	# /usr/bin needed for basename which the wrapper uses at the end of the script
	output=$(PATH="$WRAPPER_DIR:$REAL_DATE_DIR:$SUPPORT_DIR:/usr/bin" "$TIMEOUT_BIN" 3 "$BASH_BIN" "$WRAPPER" '+%Y' 2>/dev/null)
	rc=$?
	if [[ $rc -eq 0 ]] && [[ "$output" =~ ^[0-9]{4}$ ]]; then
		echo "✓ Test passed: real date used (year='$output')"
	elif [[ $rc -eq 124 ]]; then
		echo "✗ Test failed: hit 3s timeout — wrapper is recursing" >&2
		((fails++))
	else
		echo "✗ Test failed: rc=$rc output='$output'" >&2
		((fails++))
	fi
fi

# Test 3: normal PATH (gdate present) → wrapper uses gdate.
((tests++))
echo "Testing: wrapper uses gdate when available..."
output=$("$WRAPPER" '+%Y' 2>&1)
rc=$?
if [[ $rc -eq 0 ]] && [[ "$output" =~ ^[0-9]{4}$ ]]; then
	echo "✓ Test passed: year output is '$output'"
else
	echo "✗ Test failed: rc=$rc output='$output'" >&2
	((fails++))
fi

# Test 4: a controlled non-GNU fallback must produce a warning on every OS.
((tests++))
echo "Testing: wrapper warns to stderr when fallback is non-GNU..."
FALLBACK_DIR=$(mktemp -d --tmpdir date_test_fallback.XXXXXX)
printf '#!/usr/bin/env bash\nif [[ "$1" == --version ]]; then exit 1; fi\nexec %q "$@"\n' "$REAL_DATE" >"$FALLBACK_DIR/date"
chmod +x "$FALLBACK_DIR/date"
FALLBACK_PATH="$WRAPPER_DIR:$FALLBACK_DIR:$SUPPORT_DIR:/bin:/usr/bin"
err_output=$(PATH="$FALLBACK_PATH" "$TIMEOUT_BIN" 3 "$BASH_BIN" "$WRAPPER" '+%Y' 2>&1 >/dev/null)
if [[ "$err_output" == *non-GNU* ]]; then
	echo "✓ Test passed: warning emitted on non-GNU fallback"
else
	echo "✗ Test failed: expected warning, got: '$err_output'" >&2
	((fails++))
fi

# Test 5: MUTE_GNU_WRAPPER_WARNINGS=1 must suppress the warning entirely.
((tests++))
echo "Testing: MUTE_GNU_WRAPPER_WARNINGS=1 suppresses the warning..."
err_output=$(MUTE_GNU_WRAPPER_WARNINGS=1 PATH="$FALLBACK_PATH" "$TIMEOUT_BIN" 3 "$BASH_BIN" "$WRAPPER" '+%Y' 2>&1 >/dev/null)
if [[ -z "$err_output" ]]; then
	echo "✓ Test passed: no stderr output when muted"
else
	echo "✗ Test failed: warning still emitted despite mute env: '$err_output'" >&2
	((fails++))
fi

if (( fails == 0 )); then
	echo "All $tests tests passed"
else
	echo "$fails of $tests tests failed" >&2
fi
exit $fails
