#!/usr/bin/env bash

# Tests for bin/date wrapper. See bin/test/tac_test for the full design rationale.
# Bug being prevented: whichdate=date (literal name) → $whichdate resolves
# through PATH and finds the wrapper itself → infinite recursion.

fails=0
tests=0

WRAPPER="$HOME/dotfiles/bin/date"
WRAPPER_CANONICAL="$(readlink -f "$WRAPPER")"
WRAPPER_DIR="$(dirname "$WRAPPER_CANONICAL")"

# Test 1: PATH puts wrapper first AND has no gdate. Wrapper must not recurse.
# Both macOS (/bin/date BSD) and Linux (/bin/date GNU) have a system date,
# so the wrapper-with-fix should find the non-wrapper and use it. Pre-fix
# wrapper would recurse on `whichdate=date` falling through to the wrapper.
((tests++))
echo "Testing: wrapper does not recurse when only itself is the first date..."
output=$(PATH="$WRAPPER_DIR:/bin:/usr/bin" timeout 3 "$WRAPPER" '+%Y' 2>&1)
rc=$?
if [[ $rc -eq 124 ]]; then
	echo "✗ Test failed: hit 3s timeout — wrapper is recursing into itself" >&2
	((fails++))
elif [[ $rc -eq 0 ]] && [[ "$output" =~ ^[0-9]{4}$ ]]; then
	echo "✓ Test passed: rc=0, output is a 4-digit year ('$output')"
elif [[ $rc -eq 1 ]] && [[ "$output" == *Error* ]]; then
	echo "✓ Test passed: clean error (rc=1)"
else
	echo "✗ Test failed: rc=$rc output='$output'" >&2
	((fails++))
fi

# Test 2: wrapper-dir + a real date dir (no gdate) → uses real date.
((tests++))
echo "Testing: wrapper falls back to a real date when gdate is unavailable..."
REAL_DATE=""
while IFS= read -r candidate; do
	[[ -z "$candidate" ]] && continue
	canon="$(readlink -f "$candidate" 2>/dev/null)"
	if [[ "$canon" != "$WRAPPER_CANONICAL" ]]; then
		REAL_DATE="$candidate"
		break
	fi
done < <(type -aP date 2>/dev/null)

if [[ -z "$REAL_DATE" ]]; then
	echo "✓ Test skipped: no non-wrapper date on this system"
else
	REAL_DATE_DIR="$(dirname "$REAL_DATE")"
	# /usr/bin needed for basename which the wrapper uses at line 26
	output=$(PATH="$WRAPPER_DIR:$REAL_DATE_DIR:/usr/bin" timeout 3 "$WRAPPER" '+%Y' 2>&1)
	rc=$?
	if [[ $rc -eq 0 ]] && [[ "$output" =~ ^[0-9]{4}$ ]]; then
		echo "✓ Test passed: real date used (year='$output')"
	elif [[ $rc -eq 124 ]]; then
		echo "✗ Test failed: hit 3s timeout — wrapper is recursing" >&2
		((fails++))
	else
		echo "✗ Test failed: rc=$rc output='$output'" >&2
		((fails++))
	fi
fi

# Test 3: normal PATH (gdate present) → wrapper uses gdate.
((tests++))
echo "Testing: wrapper uses gdate when available..."
output=$("$WRAPPER" '+%Y' 2>&1)
rc=$?
if [[ $rc -eq 0 ]] && [[ "$output" =~ ^[0-9]{4}$ ]]; then
	echo "✓ Test passed: year output is '$output'"
else
	echo "✗ Test failed: rc=$rc output='$output'" >&2
	((fails++))
fi

if (( fails == 0 )); then
	echo "All $tests tests passed"
else
	echo "$fails of $tests tests failed" >&2
fi
exit $fails
