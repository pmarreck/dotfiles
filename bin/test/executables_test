#!/usr/bin/env bash

# Test the executables script

test_executables() {
  echo "Testing executables..."
  
  # Create a test directory with some test files
  local test_dir="/tmp/executables_test_$$_$(date +%s)"
  mkdir -p "$test_dir/bin1" "$test_dir/bin2"
  
  # Create test files
  echo '#!/bin/bash
echo "test1"' > "$test_dir/bin1/test1"
  chmod +x "$test_dir/bin1/test1"
  
  echo '#!/bin/bash
echo "test2"' > "$test_dir/bin1/test2.sh"
  chmod +x "$test_dir/bin1/test2.sh"
  
  # Create a symlink
  ln -s "$test_dir/bin1/test1" "$test_dir/bin2/test1_symlink"

  echo '#!/bin/bash
echo "bin2"' > "$test_dir/bin2/bin2_only"
  chmod +x "$test_dir/bin2/bin2_only"
  
  # Test with our test PATH
  local old_path="$PATH"
  export PATH="$test_dir/bin1:$test_dir/bin2:$PATH"
  
  # Test basic functionality (just verify the script works)
  echo "Testing basic functionality..."
  if ! output=$("$HOME/dotfiles/bin/executables" --help 2>/dev/null); then
    echo "FAIL: Command failed"
    return 1
  fi
  
  # Check if help output contains expected text
  if ! echo "$output" | grep -q "executables - Print out the names"; then
    echo "FAIL: Help output not as expected"
    return 1
  fi
  
  # Test -h/--help alias
  echo "Testing -h alias..."
  if ! help_alias_output=$("$HOME/dotfiles/bin/executables" -h 2>/dev/null); then
    echo "FAIL: -h alias failed"
    return 1
  fi

  if ! diff <(printf '%s\n' "$output") <(printf '%s\n' "$help_alias_output") >/dev/null; then
    echo "FAIL: -h output did not match --help"
    return 1
  fi

  echo "Testing -a/--about output..."
  if ! about_output=$("$HOME/dotfiles/bin/executables" -a 2>/dev/null); then
    echo "FAIL: -a option failed"
    return 1
  fi

  if [[ "$about_output" != "Print out the names of all executables available in your PATH" ]]; then
    echo "FAIL: -a output incorrect"
    echo "Got: $about_output"
    return 1
  fi

  # Test actual functionality with a quick search in test directories only
  echo "Testing actual search functionality..."
  # Build limited PATH with test dirs plus directories containing essential utilities
  local limited_path="$test_dir/bin1:$test_dir/bin2"
  local bash_dir=$(dirname "$(which bash)")
  local fd_dir=$(dirname "$(which fd)")
  [[ -n "$bash_dir" ]] && limited_path="$limited_path:$bash_dir"
  [[ -n "$fd_dir" && "$fd_dir" != "$bash_dir" ]] && limited_path="$limited_path:$fd_dir"
  if ! search_output=$(PATH="$limited_path" "$HOME/dotfiles/bin/executables" 2>&1); then
    echo "FAIL: Search command failed"
    echo "Debug: Error was: $search_output"
    return 1
  fi
  
  # Check if we found our test files
  if ! echo "$search_output" | grep -q '^test1$'; then
    echo "FAIL: Did not find test1 executable"
    return 1
  fi
  
  if ! echo "$search_output" | grep -q '^test2.sh$'; then
    echo "FAIL: Did not find test2.sh executable"
    return 1
  fi

  if ! echo "$search_output" | grep -Fx 'test1_symlink (symlinked)'; then
    echo "FAIL: Did not find symlinked executable annotation"
    return 1
  fi
  
  # Test --scripts flag
  echo "Testing --scripts flag..."
  if ! scripts_output=$(PATH="$limited_path" "$HOME/dotfiles/bin/executables" --scripts 2>/dev/null); then
    echo "FAIL: --scripts flag failed"
    return 1
  fi

  # Test path-constrained output using an absolute path
  echo "Testing path-constrained filtering with absolute path..."
  if ! filtered_output=$(PATH="$limited_path" "$HOME/dotfiles/bin/executables" "$test_dir/bin1" 2>/dev/null); then
    echo "FAIL: Path-constrained command failed"
    return 1
  fi

  if ! echo "$filtered_output" | grep -q '^test1$'; then
    echo "FAIL: Path filter did not include test1"
    return 1
  fi

  if ! echo "$filtered_output" | grep -q '^test2.sh$'; then
    echo "FAIL: Path filter did not include test2.sh"
    return 1
  fi

  if echo "$filtered_output" | grep -Fx 'test1_symlink (symlinked)'; then
    echo "FAIL: Path filter included files outside of $test_dir/bin1"
    return 1
  fi

  # Test relative path handling (".")
  echo "Testing path-constrained filtering with relative path..."
  if ! relative_output=$(cd "$test_dir" && PATH="$limited_path" "$HOME/dotfiles/bin/executables" ./bin2 2>/dev/null); then
    echo "FAIL: Relative path-constrained command failed"
    return 1
  fi
  
  if ! echo "$relative_output" | grep -q '^bin2_only$'; then
    echo "FAIL: Relative path filter did not include bin2_only"
    return 1
  fi

  if ! echo "$relative_output" | grep -Fx 'test1_symlink (symlinked)'; then
    echo "FAIL: Relative path filter did not show symlink as expected"
    return 1
  fi

  if echo "$relative_output" | grep -q '^test1$'; then
    echo "FAIL: Relative path filter included executables outside ./bin2"
    return 1
  fi
  
  # Test --ambiguate flag: no "(symlinked)" annotations, deduplicated by name
  echo "Testing --ambiguate flag..."
  if ! ambig_output=$(PATH="$limited_path" "$HOME/dotfiles/bin/executables" --ambiguate 2>/dev/null); then
    echo "FAIL: --ambiguate command failed"
    return 1
  fi

  # Should NOT have "(symlinked)" in output
  if echo "$ambig_output" | grep -q '(symlinked)'; then
    echo "FAIL: --ambiguate output still contains '(symlinked)'"
    return 1
  fi

  # test1_symlink should still appear (it's a different name)
  if ! echo "$ambig_output" | grep -q '^test1_symlink$'; then
    echo "FAIL: --ambiguate did not include test1_symlink (plain name)"
    return 1
  fi

  # test1 should appear exactly once
  local test1_count
  test1_count=$(echo "$ambig_output" | grep -c '^test1$')
  if [[ "$test1_count" -ne 1 ]]; then
    echo "FAIL: --ambiguate has $test1_count copies of test1 (expected 1)"
    return 1
  fi

  # Test --ambiguate help text appears in --help
  echo "Testing --ambiguate in help..."
  if ! echo "$output" | grep -q 'ambiguate'; then
    echo "FAIL: --help does not mention --ambiguate"
    return 1
  fi

  # Test --path flag: shows paths in a second column
  echo "Testing --path flag..."
  if ! path_output=$(PATH="$limited_path" "$HOME/dotfiles/bin/executables" --path "$test_dir/bin1" 2>/dev/null); then
    echo "FAIL: --path command failed"
    return 1
  fi

  # Output should contain the test directory path
  if ! echo "$path_output" | grep -q "$test_dir/bin1/test1"; then
    echo "FAIL: --path output does not show path for test1"
    echo "Got: $path_output"
    return 1
  fi

  # test1 name should still be in the output
  if ! echo "$path_output" | grep -q 'test1'; then
    echo "FAIL: --path output does not show name test1"
    return 1
  fi

  # Test --path with symlinks: should show source -> target
  echo "Testing --path flag with symlinks..."
  if ! path_sym_output=$(PATH="$limited_path" "$HOME/dotfiles/bin/executables" --path "$test_dir/bin2" 2>/dev/null); then
    echo "FAIL: --path with symlinks command failed"
    return 1
  fi

  # Symlink line should contain "->" showing source and target
  if ! echo "$path_sym_output" | grep 'test1_symlink' | grep -Fq -- '->'; then
    echo "FAIL: --path does not show -> for symlink"
    echo "Got: $path_sym_output"
    return 1
  fi

  # Test --path in help text
  echo "Testing --path in help..."
  if ! echo "$output" | grep -Fq -- '--path'; then
    echo "FAIL: --help does not mention --path"
    return 1
  fi

  # Clean up
  export PATH="$old_path"
  rm -rf "$test_dir"

  echo "All tests passed!"
  return 0
}

# Run the test if this script is executed directly
if ! (return 0 2>/dev/null); then
  test_executables
  exit $?
fi
