#!/usr/bin/env bash

# Test the jpegxl function
test_jpegxl() {
    local fails=0
    local tests=0

	# Create a test directory
	local test_dir=$(mktemp -d --tmpdir jpegxl_test.XXXXXX)
	echo "Running jpegxl tests in temporary directory: $test_dir"

    # Create test images in the test directory
    (
        cd "$test_dir"

        # Create a test JPEG image
        magick -size 100x100 gradient:green-yellow "$test_dir/test_jpg.jpg"

        # Create a test PNG image
        magick -size 100x100 gradient:blue-red "$test_dir/test_png.png"

        # Create a test PNG with alpha channel
        magick -size 100x100 xc:none -fill red -draw "circle 50,50 20,30" "$test_dir/alpha_test_png.png"
    )

    # Test 1: Basic lossless conversion (default)
    (( tests++ ))
    DEBUG=true jpegxl "$test_dir/test_jpg.jpg" >/dev/null 2>&1
    if [[ -f "$test_dir/test_jpg.jxl" ]]; then
        echo "✓ Basic lossless conversion test passed"
    else
        echo "✗ Basic lossless conversion test failed"
        (( fails++ ))
    fi

    # Test 2: Lossy conversion
    (( tests++ ))
    DEBUG=true jpegxl --lossy "$test_dir/test_png.png" >/dev/null 2>&1
    if [[ -f "$test_dir/test_png.jxl" ]]; then
        echo "✓ Lossy conversion test passed"
    else
        echo "✗ Lossy conversion test failed"
        (( fails++ ))
    fi

    # Test 3: Specific distance setting
    (( tests++ ))
    DEBUG=true jpegxl --distance=2 "$test_dir/test_jpg.jpg" >/dev/null 2>&1
    # We're just checking it doesn't error out - success is just producing the file
    if [[ -f "$test_dir/test_jpg.jxl" ]]; then
        echo "✓ Specific distance setting test passed"
    else
        echo "✗ Specific distance setting test failed"
        (( fails++ ))
    fi

    # Test 4: Conflicting options (should prefer --lossless over --distance=0)
    (( tests++ ))
    rm -f "$test_dir/test_jpg.jxl"
    DEBUG=true jpegxl --distance=0 --lossy "$test_dir/test_jpg.jpg" >/dev/null 2>&1
    # This test should pass if the file was created, and we'll verify the implementation later
    if [[ -f "$test_dir/test_jpg.jxl" ]]; then
        echo "✓ Conflicting options test passed"
    else
        echo "✗ Conflicting options test failed"
        (( fails++ ))
    fi

    # Test 5: PNG with alpha channel
    (( tests++ ))
    DEBUG=true jpegxl "$test_dir/alpha_test_png.png" >/dev/null 2>&1
    if [[ -f "$test_dir/alpha_test_png.jxl" ]]; then
        echo "✓ PNG with alpha channel test passed"
    else
        echo "✗ PNG with alpha channel test failed"
        (( fails++ ))
    fi

    # Test 6: Conversion back to original format
    (( tests++ ))
    DEBUG=true jpegxl --to=png "$test_dir/alpha_test_png.jxl" >/dev/null 2>&1
    if [[ -f "$test_dir/alpha_test_png.png" ]]; then
        echo "✓ Conversion back to original format test passed"
    else
        echo "✗ Conversion back to original format test failed"
        (( fails++ ))
    fi

    # Test 7: Quality setting
    (( tests++ ))
    DEBUG=true jpegxl --quality=50 "$test_dir/test_jpg.jpg" >/dev/null 2>&1
    # We're just checking it doesn't error out - success is just producing the file
    if [[ -f "$test_dir/test_jpg.jxl" ]]; then
        echo "✓ Quality setting test passed"
    else
        echo "✗ Quality setting test failed"
        (( fails++ ))
    fi

    # Helper to fetch mtime using available stat implementation
    local stat_mtime
    if command -v gstat >/dev/null 2>&1; then
        stat_mtime() { gstat -c %Y "$1"; }
    else
        stat_mtime() { stat -f %m "$1"; }
    fi

    # Test 8: Default preserves timestamps
    (( tests++ ))
    local ts_file="$test_dir/mtime_default.jpg"
    magick -size 50x50 gradient:red-blue "$ts_file"
    # Give the file a deterministic timestamp far in the past
    touch -t 200001010000 "$ts_file"
    local original_mtime
    original_mtime=$(stat_mtime "$ts_file")
    DEBUG=true jpegxl "$ts_file" >/dev/null 2>&1
    local ts_output="$test_dir/mtime_default.jxl"
    if [[ -f "$ts_output" ]]; then
        local converted_mtime
        converted_mtime=$(stat_mtime "$ts_output")
        if [[ "$converted_mtime" == "$original_mtime" ]]; then
            echo "✓ Default timestamp preservation test passed"
        else
            echo "✗ Default timestamp preservation test failed (expected $original_mtime, got $converted_mtime)" >&2
            (( fails++ ))
        fi
    else
        echo "✗ Default timestamp preservation test failed (no output file)" >&2
        (( fails++ ))
    fi

    # Test 9: About flag
    (( tests++ ))
    if jpegxl --about | grep -q "jpegxl - Convert images"; then
        echo "✓ About flag test passed"
    else
        echo "✗ About flag test failed"
        (( fails++ ))
    fi

    # Test 10: Batch processing
    (( tests++ ))
    # Create copies for batch test
    cp "$test_dir/test_jpg.jpg" "$test_dir/batch_1.jpg"
    cp "$test_dir/test_jpg.jpg" "$test_dir/batch_2.jpg"

    DEBUG=true jpegxl "$test_dir/batch_1.jpg" "$test_dir/batch_2.jpg" >/dev/null 2>&1

    if [[ -f "$test_dir/batch_1.jxl" && -f "$test_dir/batch_2.jxl" ]]; then
        echo "✓ Batch processing test passed"
    else
        echo "✗ Batch processing test failed"
        (( fails++ ))
    fi

    # Test 11: TIFF lossless conversion
    (( tests++ ))
    # Embedded 2x2 RGB TIFF (232 bytes) encoded with printable-binary
    local tif_encoded='II⁎·꞉···»ž··žŻ·»ž··žŻ·⌫·⌫·⌫·H···¯···H···¯···Lavc62.11.100·ȯ·ż·ϟ·¯········¯ϟ·¯···«···¯¯ϟ·¯···«···«¯»·»···ɨ···»¯»·¯···¿ă··¡¯»·¯···«···¹¯ϟ·¯···⌫···µ¯»·¯···»···ɨ¯ϟ·¯···Čϟ··⏹¯ϟ·¯···ȯ···Ƶ¯¿·¯···Ξ···⎋¯¿·¯···Ꞩ···❨¯»·¯···«···1¯«·ȯ···٫·······'
    local tif_file="$test_dir/test_tif.tif"
    echo -n "$tif_encoded" | PRINTABLE_BINARY_MUTE_STATS=1 printable-binary -d -S > "$tif_file"
    if magick identify "$tif_file" >/dev/null 2>&1; then
        DEBUG=true jpegxl "$tif_file" >/dev/null 2>&1
        if [[ -f "$test_dir/test_tif.jxl" ]]; then
            echo "✓ TIFF lossless conversion test passed"
        else
            echo "✗ TIFF lossless conversion test failed (no .jxl output)" >&2
            (( fails++ ))
        fi
    else
        echo "✗ TIFF lossless conversion test skipped (embedded TIFF not valid — check printable-binary)" >&2
        (( fails++ ))
    fi

    # Test 12: TIFF lossy conversion
    (( tests++ ))
    rm -f "$test_dir/test_tif.jxl"
    DEBUG=true jpegxl --lossy "$tif_file" >/dev/null 2>&1
    if [[ -f "$test_dir/test_tif.jxl" ]]; then
        echo "✓ TIFF lossy conversion test passed"
    else
        echo "✗ TIFF lossy conversion test failed (no .jxl output)" >&2
        (( fails++ ))
    fi

    # Test 13: BMP lossless conversion
    (( tests++ ))
    local bmp_file="$test_dir/test_bmp.bmp"
    magick -size 10x10 gradient:red-blue "$bmp_file"
    DEBUG=true jpegxl "$bmp_file" >/dev/null 2>&1
    if [[ -f "$test_dir/test_bmp.jxl" ]]; then
        echo "✓ BMP lossless conversion test passed"
    else
        echo "✗ BMP lossless conversion test failed (no .jxl output)" >&2
        (( fails++ ))
    fi

    # Test 14: BMP lossy conversion
    (( tests++ ))
    rm -f "$test_dir/test_bmp.jxl"
    DEBUG=true jpegxl --lossy "$bmp_file" >/dev/null 2>&1
    if [[ -f "$test_dir/test_bmp.jxl" ]]; then
        echo "✓ BMP lossy conversion test passed"
    else
        echo "✗ BMP lossy conversion test failed (no .jxl output)" >&2
        (( fails++ ))
    fi

    # Test 15: JPEG 2000 (.jp2) conversion
    (( tests++ ))
    local jp2_file="$test_dir/test_jp2.jp2"
    magick -size 10x10 gradient:red-blue "$jp2_file"
    DEBUG=true jpegxl "$jp2_file" >/dev/null 2>&1
    if [[ -f "$test_dir/test_jp2.jxl" ]]; then
        echo "✓ JPEG 2000 conversion test passed"
    else
        echo "✗ JPEG 2000 conversion test failed (no .jxl output)" >&2
        (( fails++ ))
    fi

    # Test 15b: JPEG 2000 emits lossy-source warning
    (( tests++ ))
    rm -f "$test_dir/test_jp2.jxl"
    local jp2_stderr
    jp2_stderr=$(jpegxl "$jp2_file" 2>&1 >/dev/null)
    if echo "$jp2_stderr" | grep -qi "lossy source\|typically lossy"; then
        echo "✓ JPEG 2000 lossy-source warning test passed"
    else
        echo "✗ JPEG 2000 lossy-source warning test failed (no warning on stderr)" >&2
        echo "  stderr was: $jp2_stderr" >&2
        (( fails++ ))
    fi

    # Test 16: PRESERVE_TIMESTAMPS=false disables timestamp preservation
    (( tests++ ))
    local env_ts_file="$test_dir/envts.jpg"
    magick -size 10x10 gradient:red-blue "$env_ts_file"
    touch -t 200001010000 "$env_ts_file"
    local env_orig_mtime
    env_orig_mtime=$(stat_mtime "$env_ts_file")
    PRESERVE_TIMESTAMPS=false jpegxl "$env_ts_file" >/dev/null 2>&1
    local env_ts_output="$test_dir/envts.jxl"
    if [[ -f "$env_ts_output" ]]; then
        local env_new_mtime
        env_new_mtime=$(stat_mtime "$env_ts_output")
        if [[ "$env_new_mtime" != "$env_orig_mtime" ]]; then
            echo "✓ PRESERVE_TIMESTAMPS=false test passed"
        else
            echo "✗ PRESERVE_TIMESTAMPS=false test failed (timestamps were preserved)" >&2
            (( fails++ ))
        fi
    else
        echo "✗ PRESERVE_TIMESTAMPS=false test failed (no output file)" >&2
        (( fails++ ))
    fi

    # Test 17: --preserve-timestamps overrides PRESERVE_TIMESTAMPS=false
    (( tests++ ))
    local override_file="$test_dir/override.jpg"
    magick -size 10x10 gradient:red-blue "$override_file"
    touch -t 200001010000 "$override_file"
    local override_orig_mtime
    override_orig_mtime=$(stat_mtime "$override_file")
    rm -f "$test_dir/override.jxl"
    PRESERVE_TIMESTAMPS=false jpegxl --preserve-timestamps "$override_file" >/dev/null 2>&1
    local override_output="$test_dir/override.jxl"
    if [[ -f "$override_output" ]]; then
        local override_new_mtime
        override_new_mtime=$(stat_mtime "$override_output")
        if [[ "$override_new_mtime" == "$override_orig_mtime" ]]; then
            echo "✓ CLI --preserve-timestamps overrides env var test passed"
        else
            echo "✗ CLI --preserve-timestamps override test failed (timestamps not preserved)" >&2
            (( fails++ ))
        fi
    else
        echo "✗ CLI --preserve-timestamps override test failed (no output file)" >&2
        (( fails++ ))
    fi

    # Test 18: Magick-piped path preserves timestamps (TIFF, same path as DNG)
    (( tests++ ))
    local piped_ts_file="$test_dir/piped_ts.tif"
    magick -size 10x10 gradient:red-blue "$piped_ts_file"
    touch -t 200001010000 "$piped_ts_file"
    local piped_orig_mtime
    piped_orig_mtime=$(stat_mtime "$piped_ts_file")
    jpegxl "$piped_ts_file" >/dev/null 2>&1
    local piped_ts_output="$test_dir/piped_ts.jxl"
    if [[ -f "$piped_ts_output" ]]; then
        local piped_new_mtime
        piped_new_mtime=$(stat_mtime "$piped_ts_output")
        if [[ "$piped_new_mtime" == "$piped_orig_mtime" ]]; then
            echo "✓ Magick-piped path timestamp preservation test passed"
        else
            echo "✗ Magick-piped path timestamp preservation test failed (expected $piped_orig_mtime, got $piped_new_mtime)" >&2
            (( fails++ ))
        fi
    else
        echo "✗ Magick-piped path timestamp preservation test failed (no output file)" >&2
        (( fails++ ))
    fi

    # Test 19-20: DNG lossless/lossy conversion
    # DNG files require actual raw sensor data (Bayer mosaic) that can't be
    # easily synthesized. We create a real DNG-compatible file if possible,
    # otherwise skip gracefully (not counted as a failure).
    local dng_file="$test_dir/test_dng.dng"
    local dng_available=false
    # Try to create a minimal CFA TIFF that libraw can read as DNG
    # If this doesn't work, skip DNG tests
    magick -size 10x10 gradient:red-blue TIFF:"$dng_file" 2>/dev/null
    if magick "$dng_file" png:/dev/null 2>/dev/null; then
        dng_available=true
    fi

    if [[ "$dng_available" == "true" ]]; then
        (( tests++ ))
        DEBUG=true jpegxl "$dng_file" >/dev/null 2>&1
        if [[ -f "$test_dir/test_dng.jxl" ]]; then
            echo "✓ DNG lossless conversion test passed"
        else
            echo "✗ DNG lossless conversion test failed (no .jxl output)" >&2
            (( fails++ ))
        fi

        # DNG lossy conversion
        (( tests++ ))
        rm -f "$test_dir/test_dng.jxl"
        DEBUG=true jpegxl --lossy "$dng_file" >/dev/null 2>&1
        if [[ -f "$test_dir/test_dng.jxl" ]]; then
            echo "✓ DNG lossy conversion test passed"
        else
            echo "✗ DNG lossy conversion test failed (no .jxl output)" >&2
            (( fails++ ))
        fi
    else
        echo "⊘ DNG tests skipped (cannot synthesize raw sensor data for test DNG)" >&2
    fi

    # Test 21: DNG extension routes through magick-piped path
    (( tests++ ))
    # Verify .dng goes through the ImageMagick pipe path (like TIFF/BMP)
    # by checking DEBUG output for the "piped" keyword
    local dng_route_file="$test_dir/route_test.dng"
    magick -size 2x2 xc:red TIFF:"$dng_route_file" 2>/dev/null
    local dng_debug
    dng_debug=$(DEBUG=true jpegxl "$dng_route_file" 2>&1)
    if echo "$dng_debug" | grep -q "piped"; then
        echo "✓ DNG format routing test passed (uses magick-piped path)"
    else
        echo "✗ DNG format routing test failed (should use magick-piped path)" >&2
        echo "  debug output: $dng_debug" >&2
        (( fails++ ))
    fi

	# Tests 22-25: --abort-if-larger rejects equal-or-larger output but keeps
	# smaller output. Use a controlled cjxl so the boundary is deterministic.
	local abort_mock_bin="$test_dir/abort-mock-bin"
	mkdir -p "$abort_mock_bin"
	cat <<'EOF' > "$abort_mock_bin/cjxl"
#!/usr/bin/env bash
previous_arg=""
for arg in "$@"; do
	input="$previous_arg"
	previous_arg="$arg"
done
output="$previous_arg"

case "${JPEGXL_TEST_CJXL_MODE:-larger}" in
	larger) cat "$input" "$input" "$input" "$input" > "$output" ;;
	equal) cat "$input" > "$output" ;;
	smaller) printf 'smaller output\n' > "$output" ;;
esac
EOF
	chmod +x "$abort_mock_bin/cjxl"

	(( tests++ ))
	if jpegxl --help | grep -q -- '--abort-if-larger'; then
		echo "✓ --abort-if-larger is documented"
	else
		echo "✗ --abort-if-larger is not documented" >&2
		(( fails++ ))
	fi

	(( tests++ ))
	local larger_test_file="$test_dir/larger_test.jpg"
	local larger_test_output="$test_dir/larger_test.jxl"
	magick -size 10x10 gradient:red-blue "$larger_test_file"
	local larger_result
	larger_result=$(PATH="$abort_mock_bin:$PATH" JPEGXL_TEST_CJXL_MODE=larger jpegxl --abort-if-larger "$larger_test_file" 2>&1)
	local larger_status=$?
	if [[ "$larger_status" -ne 0 && -f "$larger_test_file" && ! -e "$larger_test_output" && "$larger_result" == *"not smaller"* ]]; then
		echo "✓ --abort-if-larger discards a larger output"
	else
		echo "✗ --abort-if-larger larger-output test failed (status $larger_status: $larger_result)" >&2
		(( fails++ ))
	fi

	(( tests++ ))
	local equal_test_file="$test_dir/equal_test.jpg"
	local equal_test_output="$test_dir/equal_test.jxl"
	magick -size 10x10 gradient:red-blue "$equal_test_file"
	local equal_result
	equal_result=$(PATH="$abort_mock_bin:$PATH" JPEGXL_TEST_CJXL_MODE=equal jpegxl --abort-if-larger "$equal_test_file" 2>&1)
	local equal_status=$?
	if [[ "$equal_status" -ne 0 && -f "$equal_test_file" && ! -e "$equal_test_output" && "$equal_result" == *"not smaller"* ]]; then
		echo "✓ --abort-if-larger discards an equal-sized output"
	else
		echo "✗ --abort-if-larger equal-size test failed (status $equal_status: $equal_result)" >&2
		(( fails++ ))
	fi

	(( tests++ ))
	local smaller_test_file="$test_dir/smaller_test.jpg"
	local smaller_test_output="$test_dir/smaller_test.jxl"
	magick -size 10x10 gradient:red-blue "$smaller_test_file"
	PATH="$abort_mock_bin:$PATH" JPEGXL_TEST_CJXL_MODE=smaller jpegxl --abort-if-larger "$smaller_test_file" >/dev/null 2>&1
	local smaller_status=$?
	if [[ "$smaller_status" -eq 0 && -f "$smaller_test_file" && -f "$smaller_test_output" ]]; then
		echo "✓ --abort-if-larger keeps a smaller output"
	else
		echo "✗ --abort-if-larger smaller-output test failed (status $smaller_status)" >&2
		(( fails++ ))
	fi

	# Test 26: --trash-original removes the original using an isolated Trash.
	# gio is deliberately made to fail on Linux: it often cannot trash files from
	# temporary or network filesystems, so jpegxl must use its fallback instead.
	local trash_mock_bin="$test_dir/trash-mock-bin"
	local isolated_data_home="$test_dir/xdg-data"
	local mock_trash_dir="$test_dir/mock-trash"
	mkdir -p "$trash_mock_bin" "$isolated_data_home" "$mock_trash_dir"
	if [[ "$OSTYPE" == "darwin"* ]]; then
		cat <<'EOF' > "$trash_mock_bin/trash"
#!/usr/bin/env bash
mkdir -p "$JPEGXL_TEST_TRASH_DIR"
mv "$1" "$JPEGXL_TEST_TRASH_DIR/"
EOF
		chmod +x "$trash_mock_bin/trash"
	else
		cat <<'EOF' > "$trash_mock_bin/gio"
#!/usr/bin/env bash
exit 1
EOF
		chmod +x "$trash_mock_bin/gio"
	fi

	(( tests++ ))
	local trash_test_file="$test_dir/trash_test.jpg"
	magick -size 10x10 gradient:red-blue "$trash_test_file"
	PATH="$trash_mock_bin:$PATH" XDG_DATA_HOME="$isolated_data_home" JPEGXL_TEST_TRASH_DIR="$mock_trash_dir" DEBUG=true jpegxl --trash-original "$trash_test_file" >/dev/null 2>&1
	if [[ "$OSTYPE" == "darwin"* ]]; then
		local trash_test_destination="$mock_trash_dir/trash_test.jpg"
	else
		local trash_test_destination="$isolated_data_home/Trash/files/trash_test.jpg"
	fi
	if [[ ! -f "$trash_test_file" && -f "$test_dir/trash_test.jxl" && -f "$trash_test_destination" ]]; then
		echo "✓ --trash-original test passed"
	else
		echo "✗ --trash-original test failed" >&2
		(( fails++ ))
	fi

	# Test 27: --trash-originals (plural alias) follows the same path.
	(( tests++ ))
	local plural_test_file="$test_dir/plural_test.jpg"
	magick -size 10x10 gradient:red-blue "$plural_test_file"
	PATH="$trash_mock_bin:$PATH" XDG_DATA_HOME="$isolated_data_home" JPEGXL_TEST_TRASH_DIR="$mock_trash_dir" DEBUG=true jpegxl --trash-originals "$plural_test_file" >/dev/null 2>&1
	if [[ "$OSTYPE" == "darwin"* ]]; then
		local plural_test_destination="$mock_trash_dir/plural_test.jpg"
	else
		local plural_test_destination="$isolated_data_home/Trash/files/plural_test.jpg"
	fi
	if [[ ! -f "$plural_test_file" && -f "$test_dir/plural_test.jxl" && -f "$plural_test_destination" ]]; then
		echo "✓ --trash-originals (plural alias) test passed"
	else
		echo "✗ --trash-originals (plural alias) test failed" >&2
		(( fails++ ))
	fi

    # Clean up test directory
    echo "Cleaning up test directory..."
    rm -rf "$test_dir"

    # Report results
    if [ $fails -gt 0 ]; then
        echo "$fails of $tests jpegxl tests failed!" >&2
    else
        echo "All $tests jpegxl tests passed!" >&2
    fi

    return $fails
}

# Run the test if this script is executed directly
    test_jpegxl
