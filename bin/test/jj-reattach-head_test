#!/usr/bin/env bash
# jj-reattach-head_test — verifies the post-`jj commit` HEAD reattachment.
#
# Each scenario runs in its own subshell with its own colocated jj+git
# repo under mktemp. `jj commit` naturally puts .git/HEAD into the detached
# state (raw SHA of @-), so we just exercise that state with various
# bookmark layouts on @- and check the script's behavior.

set -u

export PATH="$HOME/dotfiles/bin:$PATH"

tests=0
fails=0

pass() { ((tests++)); echo "✓ $1"; }
fail() { ((tests++)); ((fails++)) || :; echo "✗ $1" >&2; [ -n "${2:-}" ] && echo "  $2" >&2 || :; }

# A subshell-bodied function: cwd/trap effects don't escape.
# Usage: in_repo {body code}; returns body's rc.
in_repo() (
	set -u
	d=$(mktemp -d --tmpdir jj_reattach_test.XXXXXX)
	trap '/bin/rm -rf "$d"' EXIT
	cd "$d" || return 99
	jj git init --colocate >/dev/null 2>&1 || { echo "jj init failed" >&2; return 99; }
	eval "$1"
)

# ─── single bookmark on @- → HEAD attached to its ref ─────────────────────
echo "==> single bookmark on @- → HEAD attached"
err=$(in_repo '
	echo x > f.txt
	jj commit -m "first" >/dev/null 2>&1
	jj bookmark create yolo -r "@-" >/dev/null 2>&1
	out=$(jj-reattach-head 2>&1); rc=$?
	head=$(cat .git/HEAD)
	[ "$rc" -eq 0 ] || { echo "exit=$rc out=$out"; exit 1; }
	[ "$head" = "ref: refs/heads/yolo" ] || { echo "HEAD=$head"; exit 1; }
' 2>&1)
[ $? -eq 0 ] && pass "single bookmark → HEAD = ref: refs/heads/yolo" || fail "single bookmark" "$err"

# ─── single bookmark named master (not just yolo) ────────────────────────
echo "==> single bookmark on @- (master) → HEAD attached"
err=$(in_repo '
	echo x > f.txt
	jj commit -m "first" >/dev/null 2>&1
	jj bookmark create master -r "@-" >/dev/null 2>&1
	out=$(jj-reattach-head 2>&1); rc=$?
	head=$(cat .git/HEAD)
	[ "$rc" -eq 0 ] || { echo "exit=$rc out=$out"; exit 1; }
	[ "$head" = "ref: refs/heads/master" ] || { echo "HEAD=$head"; exit 1; }
' 2>&1)
[ $? -eq 0 ] && pass "single bookmark master → HEAD = ref: refs/heads/master" || fail "single master bookmark" "$err"

# ─── multiple bookmarks on @- → exits nonzero, names them on stderr ──────
echo "==> multiple bookmarks on @- → loud failure"
err=$(in_repo '
	echo x > f.txt
	jj commit -m "first" >/dev/null 2>&1
	jj bookmark create yolo -r "@-" >/dev/null 2>&1
	jj bookmark create stable -r "@-" >/dev/null 2>&1
	out=$(jj-reattach-head 2>&1); rc=$?
	[ "$rc" -ne 0 ] || { echo "expected nonzero exit; got 0 out=$out"; exit 1; }
	case "$out" in
		*yolo*stable*|*stable*yolo*) : ;;
		*) echo "stderr should name both bookmarks; got: $out"; exit 1 ;;
	esac
' 2>&1)
[ $? -eq 0 ] && pass "multi-bookmark → exits nonzero + names both" || fail "multi-bookmark" "$err"

# ─── no bookmark on @- → exits nonzero ───────────────────────────────────
echo "==> no bookmark on @- → loud failure"
err=$(in_repo '
	echo x > f.txt
	jj commit -m "first" >/dev/null 2>&1
	# Deliberately no bookmark creation.
	out=$(jj-reattach-head 2>&1); rc=$?
	[ "$rc" -ne 0 ] || { echo "expected nonzero exit; got 0 out=$out"; exit 1; }
' 2>&1)
[ $? -eq 0 ] && pass "no bookmark on @- → exits nonzero" || fail "no bookmark" "$err"

# ─── explicit arg overrides multi-bookmark ambiguity ─────────────────────
echo "==> explicit arg overrides multi-bookmark error"
err=$(in_repo '
	echo x > f.txt
	jj commit -m "first" >/dev/null 2>&1
	jj bookmark create yolo -r "@-" >/dev/null 2>&1
	jj bookmark create stable -r "@-" >/dev/null 2>&1
	out=$(jj-reattach-head yolo 2>&1); rc=$?
	head=$(cat .git/HEAD)
	[ "$rc" -eq 0 ] || { echo "exit=$rc out=$out"; exit 1; }
	[ "$head" = "ref: refs/heads/yolo" ] || { echo "HEAD=$head"; exit 1; }
' 2>&1)
[ $? -eq 0 ] && pass "explicit yolo arg → HEAD = ref: refs/heads/yolo" || fail "explicit arg" "$err"

# ─── idempotent: already-attached HEAD stays attached (and matches arg) ──
echo "==> idempotent on already-attached HEAD"
err=$(in_repo '
	echo x > f.txt
	jj commit -m "first" >/dev/null 2>&1
	jj bookmark create yolo -r "@-" >/dev/null 2>&1
	jj-reattach-head >/dev/null 2>&1  # first attach
	first=$(cat .git/HEAD)
	jj-reattach-head >/dev/null 2>&1  # second invocation should be a no-op
	rc=$?
	second=$(cat .git/HEAD)
	[ "$rc" -eq 0 ] || { echo "second invocation rc=$rc"; exit 1; }
	[ "$first" = "$second" ] || { echo "HEAD changed: $first → $second"; exit 1; }
	[ "$second" = "ref: refs/heads/yolo" ] || { echo "HEAD wrong: $second"; exit 1; }
' 2>&1)
[ $? -eq 0 ] && pass "idempotent reattach" || fail "idempotent" "$err"

echo
if [ "$fails" -eq 0 ]; then
	echo "All $tests jj-reattach-head tests passed"
else
	echo "$fails of $tests jj-reattach-head tests failed" >&2
fi
exit "$fails"
