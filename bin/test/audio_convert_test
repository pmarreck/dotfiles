#!/usr/bin/env bash

test_audio_convert() {
	local fails=0
	local tests=0

	# Test 1: --help exits 0 and mentions "Usage"
	(( tests++ ))
	if audio-convert --help 2>&1 | grep -qi "usage"; then
		echo "✓ audio-convert --help test passed"
	else
		echo "✗ audio-convert --help test failed" >&2
		(( fails++ ))
	fi

	# Test 2: --about is exactly one line
	(( tests++ ))
	local about_lines
	about_lines=$(audio-convert --about 2>&1 | wc -l | tr -d ' ')
	if [[ "$about_lines" == "1" ]]; then
		echo "✓ audio-convert --about is one line test passed"
	else
		echo "✗ audio-convert --about is one line test failed (got $about_lines lines)" >&2
		(( fails++ ))
	fi

	# Test 3: Each alias has distinct --about output mentioning its name
	for alias_name in mp3 aac m4a flac alac; do
		(( tests++ ))
		local about_out
		about_out=$("$alias_name" --about 2>&1)
		if [[ "$about_out" == "$alias_name - "* ]]; then
			echo "✓ $alias_name --about starts with '$alias_name - ' test passed"
		else
			echo "✗ $alias_name --about starts with '$alias_name - ' test failed" >&2
			echo "  got: $about_out" >&2
			(( fails++ ))
		fi
	done

	# Test: audio-convert with no --format exits non-zero and lists valid formats
	(( tests++ ))
	local noformat_stderr
	local noformat_rc
	noformat_stderr=$(audio-convert nofile.wav 2>&1 >/dev/null)
	noformat_rc=$?
	if [[ "$noformat_rc" -ne 0 ]] && echo "$noformat_stderr" | grep -qE "mp3.*aac.*flac.*alac"; then
		echo "✓ audio-convert requires --format test passed"
	else
		echo "✗ audio-convert requires --format test failed (rc=$noformat_rc)" >&2
		echo "  stderr: $noformat_stderr" >&2
		(( fails++ ))
	fi

	# Test: alias + --format override warns
	(( tests++ ))
	local override_stderr
	override_stderr=$(mp3 --format=flac nofile.wav 2>&1 >/dev/null)
	if echo "$override_stderr" | grep -qi -- "--format=flac overrides alias mp3"; then
		echo "✓ alias override warning test passed"
	else
		echo "✗ alias override warning test failed" >&2
		echo "  stderr: $override_stderr" >&2
		(( fails++ ))
	fi

	# Test: alias + matching --format does NOT warn
	(( tests++ ))
	local match_stderr
	match_stderr=$(mp3 --format=mp3 nofile.wav 2>&1 >/dev/null)
	if ! echo "$match_stderr" | grep -qi "overrides alias"; then
		echo "✓ alias + matching format does not warn test passed"
	else
		echo "✗ alias + matching format should not warn test failed" >&2
		echo "  stderr: $match_stderr" >&2
		(( fails++ ))
	fi

	# Report
	if [ $fails -gt 0 ]; then
		echo "$fails of $tests audio-convert tests failed!" >&2
	else
		echo "All $tests audio-convert tests passed!" >&2
	fi
	return $fails
}

if ! (return 0 2>/dev/null); then
	test_audio_convert
fi
