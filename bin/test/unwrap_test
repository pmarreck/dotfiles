#!/usr/bin/env bash

test_unwrap() {
	local fails=0
	local tests=0
	local actual
	local expected
	local description

	check_equal() {
		actual="$1"
		expected="$2"
		description="$3"
		(( tests++ ))
		if [[ "$actual" == "$expected" ]]; then
			printf '✓ %s\n' "$description"
		else
			printf '✗ %s\nExpected: %q\nActual:   %q\n' "$description" "$expected" "$actual" >&2
			(( fails++ ))
		fi
	}

	check_equal "$(printf 'foo\nbar\n' | unwrap)" 'foo bar' \
		'unwrap joins lines and trims trailing whitespace'
	check_equal "$(printf 'foo   \n   bar\n   baz' | unwrap)" 'foo bar baz' \
		'unwrap collapses whitespace around line breaks'
	check_equal "$(printf 'foo bar baz' | unwrap)" 'foo bar baz' \
		'unwrap preserves single-line input'
	check_equal "$(printf '' | unwrap)" '' \
		'unwrap handles empty input'

	if (( fails > 0 )); then
		printf '%s of %s unwrap tests failed!\n' "$fails" "$tests" >&2
	else
		printf 'All %s unwrap tests passed!\n' "$tests"
	fi
	return "$fails"
}

test_unwrap
