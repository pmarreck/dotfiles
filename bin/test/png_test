#!/usr/bin/env bash

# Test the png converter
test_png() {
	local fails=0
	local tests=0

	local test_dir=$(mktemp --tmpdir -d png_test.XXXXXX)
	echo "Running png tests in temporary directory: $test_dir"

	# Create test images
	magick -size 50x50 gradient:green-yellow "$test_dir/source.jpg"
	magick -size 50x50 gradient:blue-red "$test_dir/source.png"
	magick -size 50x50 xc:none -fill red -draw "circle 25,25 10,15" "$test_dir/alpha.png"
	# Create a lossless JXL from PNG (d=0)
	cjxl -e 3 -d 0 "$test_dir/source.png" "$test_dir/lossless.jxl" 2>/dev/null
	# Create a lossy JXL from PNG (d=1)
	cjxl -e 3 -d 1 "$test_dir/source.png" "$test_dir/lossy.jxl" 2>/dev/null
	# Create a JXL with alpha
	cjxl -e 3 -d 0 "$test_dir/alpha.png" "$test_dir/alpha.jxl" 2>/dev/null

	# Test 1: Convert lossless JXL to PNG (no warning expected)
	(( tests++ ))
	local output
	output=$(png "$test_dir/lossless.jxl" 2>/dev/null)
	if [[ -f "$test_dir/lossless.png" ]]; then
		echo "✓ Lossless JXL to PNG conversion test passed"
	else
		echo "✗ Lossless JXL to PNG conversion test failed (no .png output)" >&2
		(( fails++ ))
	fi

	# Test 2: Convert lossy JXL to PNG — should emit warning on stderr
	(( tests++ ))
	local stderr_output
	stderr_output=$(png "$test_dir/lossy.jxl" 2>&1 >/dev/null)
	if [[ -f "$test_dir/lossy.png" ]]; then
		if echo "$stderr_output" | grep -qi "lossy\|artifact\|warning"; then
			echo "✓ Lossy JXL warning test passed"
		else
			echo "✗ Lossy JXL warning test failed (no warning on stderr)" >&2
			echo "  stderr was: $stderr_output" >&2
			(( fails++ ))
		fi
	else
		echo "✗ Lossy JXL to PNG conversion test failed (no .png output)" >&2
		(( fails++ ))
	fi

	# Test 3: Convert JPEG to PNG — should emit warning on stderr
	(( tests++ ))
	stderr_output=$(png "$test_dir/source.jpg" 2>&1 >/dev/null)
	if [[ -f "$test_dir/source.png" ]]; then
		# source.png already exists from setup; remove it and reconvert
		rm -f "$test_dir/source.png"
		# Use a uniquely named JPEG
		cp "$test_dir/source.jpg" "$test_dir/from_jpeg.jpg"
		stderr_output=$(png "$test_dir/from_jpeg.jpg" 2>&1 >/dev/null)
		if [[ -f "$test_dir/from_jpeg.png" ]]; then
			if echo "$stderr_output" | grep -qi "lossy\|artifact\|warning"; then
				echo "✓ JPEG lossy warning test passed"
			else
				echo "✗ JPEG lossy warning test failed (no warning on stderr)" >&2
				echo "  stderr was: $stderr_output" >&2
				(( fails++ ))
			fi
		else
			echo "✗ JPEG to PNG conversion test failed (no .png output)" >&2
			(( fails++ ))
		fi
	else
		echo "✗ JPEG to PNG conversion test failed (no .png output)" >&2
		(( fails++ ))
	fi

	# Test 4: JXL with alpha channel preserved in PNG
	(( tests++ ))
	rm -f "$test_dir/alpha.png"
	png "$test_dir/alpha.jxl" >/dev/null 2>&1
	if [[ -f "$test_dir/alpha.png" ]]; then
		# Check the PNG actually has an alpha channel
		local has_alpha
		has_alpha=$(magick identify -verbose "$test_dir/alpha.png" 2>/dev/null | grep -c "Alpha")
		if [[ "$has_alpha" -gt 0 ]]; then
			echo "✓ Alpha channel preservation test passed"
		else
			echo "✗ Alpha channel preservation test failed (no alpha in output PNG)" >&2
			(( fails++ ))
		fi
	else
		echo "✗ Alpha JXL to PNG conversion test failed (no .png output)" >&2
		(( fails++ ))
	fi

	# Test 5: Timestamp preservation (default behavior)
	(( tests++ ))
	local ts_file="$test_dir/ts_test.png"
	magick -size 10x10 gradient:red-blue "$ts_file"
	cjxl -e 3 -d 0 "$ts_file" "$test_dir/ts_test.jxl" 2>/dev/null
	touch -t 200001010000 "$test_dir/ts_test.jxl"
	local stat_mtime
	if command -v gstat >/dev/null 2>&1; then
		stat_mtime() { gstat -c %Y "$1"; }
	else
		stat_mtime() { stat -f %m "$1"; }
	fi
	local original_mtime
	original_mtime=$(stat_mtime "$test_dir/ts_test.jxl")
	rm -f "$ts_file"
	png "$test_dir/ts_test.jxl" >/dev/null 2>&1
	if [[ -f "$ts_file" ]]; then
		local converted_mtime
		converted_mtime=$(stat_mtime "$ts_file")
		if [[ "$converted_mtime" == "$original_mtime" ]]; then
			echo "✓ Timestamp preservation test passed"
		else
			echo "✗ Timestamp preservation test failed (expected $original_mtime, got $converted_mtime)" >&2
			(( fails++ ))
		fi
	else
		echo "✗ Timestamp preservation test failed (no output file)" >&2
		(( fails++ ))
	fi

	# Test 6: Batch processing
	(( tests++ ))
	magick -size 10x10 gradient:red-blue "$test_dir/batch_src.png"
	cjxl -e 3 -d 0 "$test_dir/batch_src.png" "$test_dir/batch1.jxl" 2>/dev/null
	cjxl -e 3 -d 0 "$test_dir/batch_src.png" "$test_dir/batch2.jxl" 2>/dev/null
	png "$test_dir/batch1.jxl" "$test_dir/batch2.jxl" >/dev/null 2>&1
	if [[ -f "$test_dir/batch1.png" && -f "$test_dir/batch2.png" ]]; then
		echo "✓ Batch processing test passed"
	else
		echo "✗ Batch processing test failed" >&2
		(( fails++ ))
	fi

	# Test 7: --help flag
	(( tests++ ))
	if png --help 2>&1 | grep -qi "usage"; then
		echo "✓ Help flag test passed"
	else
		echo "✗ Help flag test failed" >&2
		(( fails++ ))
	fi

	# Test 8: --about flag
	(( tests++ ))
	if png --about 2>&1 | grep -q "png - Convert"; then
		echo "✓ About flag test passed"
	else
		echo "✗ About flag test failed" >&2
		(( fails++ ))
	fi

	# Test 9: TIFF to PNG conversion (lossless, no warning)
	(( tests++ ))
	# Embedded 2x2 RGB TIFF (232 bytes) encoded with printable-binary
	local tif_encoded='II⁎·꞉···»ž··žŻ·»ž··žŻ·⌫·⌫·⌫·H···¯···H···¯···Lavc62.11.100·ȯ·ż·ϟ·¯········¯ϟ·¯···«···¯¯ϟ·¯···«···«¯»·»···ɨ···»¯»·¯···¿ă··¡¯»·¯···«···¹¯ϟ·¯···⌫···µ¯»·¯···»···ɨ¯ϟ·¯···Čϟ··⏹¯ϟ·¯···ȯ···Ƶ¯¿·¯···Ξ···⎋¯¿·¯···Ꞩ···❨¯»·¯···«···1¯«·ȯ···٫·······'
	local tif_file="$test_dir/test_tif.tif"
	echo -n "$tif_encoded" | PRINTABLE_BINARY_MUTE_STATS=1 printable-binary -d -S > "$tif_file"
	if magick identify "$tif_file" >/dev/null 2>&1; then
		stderr_output=$(png "$tif_file" 2>&1 >/dev/null)
		if [[ -f "$test_dir/test_tif.png" ]]; then
			# TIFF is lossless, so no warning expected
			if echo "$stderr_output" | grep -qi "lossy\|artifact\|warning"; then
				echo "✗ TIFF to PNG should not warn (TIFF is lossless)" >&2
				(( fails++ ))
			else
				echo "✓ TIFF to PNG conversion test passed"
			fi
		else
			echo "✗ TIFF to PNG conversion test failed (no .png output)" >&2
			(( fails++ ))
		fi
	else
		echo "✗ TIFF to PNG test skipped (embedded TIFF not valid — check printable-binary)" >&2
		(( fails++ ))
	fi

	# Test 10: Lossless JXL to PNG — should NOT emit warning
	(( tests++ ))
	rm -f "$test_dir/lossless.png"
	stderr_output=$(png "$test_dir/lossless.jxl" 2>&1 >/dev/null)
	if [[ -f "$test_dir/lossless.png" ]]; then
		if echo "$stderr_output" | grep -qi "lossy\|artifact\|warning"; then
			echo "✗ Lossless JXL should not emit warning but did" >&2
			echo "  stderr was: $stderr_output" >&2
			(( fails++ ))
		else
			echo "✓ Lossless JXL no-warning test passed"
		fi
	else
		echo "✗ Lossless JXL no-warning test failed (no .png output)" >&2
		(( fails++ ))
	fi

	# Test 11: JPEG-transcoded JXL should warn (JPEG reconstruction data = lossy source)
	(( tests++ ))
	magick -size 10x10 gradient:red-blue "$test_dir/jpeg_src.jpg"
	cjxl -e 3 --lossless_jpeg=1 "$test_dir/jpeg_src.jpg" "$test_dir/jpeg_transcoded.jxl" 2>/dev/null
	stderr_output=$(png "$test_dir/jpeg_transcoded.jxl" 2>&1 >/dev/null)
	if [[ -f "$test_dir/jpeg_transcoded.png" ]]; then
		if echo "$stderr_output" | grep -qi "lossy\|artifact\|warning"; then
			echo "✓ JPEG-transcoded JXL warning test passed"
		else
			echo "✗ JPEG-transcoded JXL should warn but didn't" >&2
			echo "  stderr was: $stderr_output" >&2
			(( fails++ ))
		fi
	else
		echo "✗ JPEG-transcoded JXL conversion test failed (no .png output)" >&2
		(( fails++ ))
	fi

	# Test 12: Overwrite protection in non-interactive terminal (should error)
	(( tests++ ))
	magick -size 10x10 gradient:red-blue "$test_dir/existing.png"
	cjxl -e 3 -d 0 "$test_dir/existing.png" "$test_dir/existing.jxl" 2>/dev/null
	# existing.png already exists; converting existing.jxl should refuse
	stderr_output=$(png "$test_dir/existing.jxl" 2>&1 >/dev/null)
	local exit_code=$?
	if [[ "$exit_code" -ne 0 ]] && echo "$stderr_output" | grep -qi "exists\|overwrite"; then
		echo "✓ Overwrite protection (non-interactive) test passed"
	else
		echo "✗ Overwrite protection (non-interactive) test failed (exit=$exit_code)" >&2
		echo "  stderr was: $stderr_output" >&2
		(( fails++ ))
	fi

	# Test 13: --force flag allows overwrite
	(( tests++ ))
	# existing.png still exists from test 12
	local before_size=$($STAT -c "%s" "$test_dir/existing.png" 2>/dev/null)
	png --force "$test_dir/existing.jxl" >/dev/null 2>&1
	exit_code=$?
	if [[ "$exit_code" -eq 0 && -f "$test_dir/existing.png" ]]; then
		echo "✓ Force overwrite test passed"
	else
		echo "✗ Force overwrite test failed (exit=$exit_code)" >&2
		(( fails++ ))
	fi

	# Test 14: PRESERVE_TIMESTAMPS=false disables timestamp preservation
	(( tests++ ))
	magick -size 10x10 gradient:red-blue "$test_dir/envts_src.png"
	cjxl -e 3 -d 0 "$test_dir/envts_src.png" "$test_dir/envts.jxl" 2>/dev/null
	touch -t 200001010000 "$test_dir/envts.jxl"
	local env_orig_mtime
	env_orig_mtime=$(stat_mtime "$test_dir/envts.jxl")
	rm -f "$test_dir/envts.png"
	PRESERVE_TIMESTAMPS=false png "$test_dir/envts.jxl" >/dev/null 2>&1
	if [[ -f "$test_dir/envts.png" ]]; then
		local env_new_mtime
		env_new_mtime=$(stat_mtime "$test_dir/envts.png")
		if [[ "$env_new_mtime" != "$env_orig_mtime" ]]; then
			echo "✓ PRESERVE_TIMESTAMPS=false test passed"
		else
			echo "✗ PRESERVE_TIMESTAMPS=false test failed (timestamps were preserved)" >&2
			(( fails++ ))
		fi
	else
		echo "✗ PRESERVE_TIMESTAMPS=false test failed (no output file)" >&2
		(( fails++ ))
	fi

	# Test 15: --preserve-timestamps overrides PRESERVE_TIMESTAMPS=false
	(( tests++ ))
	cjxl -e 3 -d 0 "$test_dir/envts_src.png" "$test_dir/envts_override.jxl" 2>/dev/null
	touch -t 200001010000 "$test_dir/envts_override.jxl"
	local override_orig_mtime
	override_orig_mtime=$(stat_mtime "$test_dir/envts_override.jxl")
	PRESERVE_TIMESTAMPS=false png --preserve-timestamps "$test_dir/envts_override.jxl" >/dev/null 2>&1
	if [[ -f "$test_dir/envts_override.png" ]]; then
		local override_new_mtime
		override_new_mtime=$(stat_mtime "$test_dir/envts_override.png")
		if [[ "$override_new_mtime" == "$override_orig_mtime" ]]; then
			echo "✓ CLI --preserve-timestamps overrides env var test passed"
		else
			echo "✗ CLI --preserve-timestamps override test failed" >&2
			(( fails++ ))
		fi
	else
		echo "✗ CLI --preserve-timestamps override test failed (no output file)" >&2
		(( fails++ ))
	fi

	# Clean up test directory
	echo "Cleaning up test directory..."
	rm -rf "$test_dir"

	# Report results
	if [ $fails -gt 0 ]; then
		echo "$fails of $tests png tests failed!" >&2
	else
		echo "All $tests png tests passed!"
	fi

	return $fails
}

# Run the test if this script is executed directly
if ! (return 0 2>/dev/null); then
	test_png
fi
