#!/usr/bin/env bash

test_wrap() {
	local fails=0
	local tests=0
	local actual
	local expected
	local description

	check_equal() {
		actual="$1"
		expected="$2"
		description="$3"
		(( tests++ ))
		if [[ "$actual" == "$expected" ]]; then
			printf '✓ %s\n' "$description"
		else
			printf '✗ %s\nExpected: %q\nActual:   %q\n' "$description" "$expected" "$actual" >&2
			(( fails++ ))
		fi
	}

	check_equal "$(printf '%s' 'foo bar baz quux' | wrap 10)" $'foo bar \nbaz quux' \
		'wrap wraps at the requested word boundary'
	check_equal "$(printf '%s' 'abcdefghij' | wrap 5)" $'abcde\nfghij' \
		'wrap hard-wraps a word at the requested width'
	check_equal "$(printf 'foo bar \nbaz quux' | wrap 10)" $'foo bar \nbaz quux' \
		'wrap preserves existing line breaks'
	check_equal "$(printf '' | wrap 10)" '' \
		'wrap handles empty input'

	if (( fails > 0 )); then
		printf '%s of %s wrap tests failed!\n' "$fails" "$tests" >&2
	else
		printf 'All %s wrap tests passed!\n' "$tests"
	fi
	return "$fails"
}

test_wrap
