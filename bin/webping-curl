#!/usr/bin/env bash

# Wrapper script for webping to handle complex curl commands with proper headers
# Usage: webping-curl <url>
#
# If WEBPING_STATS_DIR is set to an existing writable directory, this script
# also appends the wall-clock duration of the curl invocation (seconds, float)
# to a per-site log file there:
#   $WEBPING_STATS_DIR/<safe-slug>.log
#
# Wall-clock (via $EPOCHREALTIME, bash 5+) is used rather than curl's own
# time_total so the value matches what gping graphs in the panes.

# Source shared function for bot-detection-resistant curl arguments
source "${BASH_SOURCE[0]%/*}/src/_get_bot_detection_resistant_curl_args_for_site.bash"

url="$1"

if [[ -z "$url" ]]; then
	echo "Usage: webping-curl <url>" >&2
	exit 1
fi

# Timeouts to avoid hanging. Override with WEBPING_CONNECT_TIMEOUT and WEBPING_MAX_TIME
CONNECT_TIMEOUT="${WEBPING_CONNECT_TIMEOUT:-5}"
MAX_TIME="${WEBPING_MAX_TIME:-20}"

# Read curl args one-per-line into an array — preserves quoted/spaced values
# without needing eval.
declare -a CURL_ARGS=()
while IFS= read -r line; do
	CURL_ARGS+=("$line")
done < <(get_curl_args "$url")

start="${EPOCHREALTIME:-}"
curl -L -s -o /dev/null --connect-timeout "$CONNECT_TIMEOUT" --max-time "$MAX_TIME" "${CURL_ARGS[@]}" "$url" >/dev/null 2>&1 || true
end="${EPOCHREALTIME:-}"

if [[ -n "${WEBPING_STATS_DIR:-}" && -d "${WEBPING_STATS_DIR}" && -n "$start" && -n "$end" ]]; then
	elapsed=$(awk -v s="$start" -v e="$end" 'BEGIN { printf "%.6f", e-s }')
	if [[ -n "$elapsed" ]]; then
		safe=$(printf '%s' "$url" | tr -c 'A-Za-z0-9._-' '_')
		# Best-effort append; never fail the ping cycle on logging issues.
		printf '%s\n' "$elapsed" >> "${WEBPING_STATS_DIR}/${safe}.log" 2>/dev/null || true
	fi
fi

exit 0
