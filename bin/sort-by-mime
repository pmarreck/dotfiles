#!/usr/bin/env bash

# sort-by-mime: Sort a file list by MIME type for better compression grouping.
# Uses `file --mime-type` for content detection and ASCII Unit Separator (0x1F)
# internally to safely handle any filename.

sort_by_mime() {
	local null_mode=0
	local reverse=""

	while [[ $# -gt 0 ]]; do
		case "$1" in
			-a|--about)
				echo "sort-by-mime: sort a file list by MIME type for better compression grouping."
				return 0
				;;
			-h|--help)
				cat <<'EOF'
usage: sort-by-mime [OPTIONS] < file-list

Reads file paths from stdin, detects each file's MIME type via `file`,
and outputs the paths sorted by MIME type. Files of the same type are
grouped together, which dramatically improves compression ratios with
any dictionary-based compressor (gzip, xz, zstd, lzma2, etc.).

Options:
  -h, --help     Show this help
  -a, --about    One-line description
  -0, --null     Null-delimited input/output (for filenames with newlines)
  -r, --reverse  Reverse sort order
  --test         Run test suite

Examples:
  # Compress a directory with MIME-sorted tar for better compression:
  find ~/Documents -type f | sort-by-mime | tar --no-recursion -T - -cJ -f sorted.tar.xz

  # Same, but safe for filenames with spaces/newlines:
  find ~/Documents -type f -print0 | sort-by-mime -0 | tar --no-recursion --null -T - -cJ -f sorted.tar.xz

  # See the grouping (MIME type + path):
  find . -type f | sort-by-mime | file --mime-type -f -
EOF
				return 0
				;;
			-0|--null)
				null_mode=1
				shift
				;;
			-r|--reverse)
				reverse="-r"
				shift
				;;
			--test)
				local test_file
				test_file="$(dirname "${BASH_SOURCE[0]}")/test/sort-by-mime_test"
				if [[ -f "$test_file" ]]; then
					exec "$test_file"
				else
					echo "Test file not found: $test_file" >&2
					return 127
				fi
				;;
			*)
				echo "sort-by-mime: unknown option: $1" >&2
				echo "Try 'sort-by-mime --help' for usage." >&2
				return 1
				;;
		esac
	done

	local SEP
	SEP=$(printf '\x1f')

	if [[ "$null_mode" -eq 1 ]]; then
		# Null-delimited mode: convert null→newline for `file`, process, convert back.
		# Note: filenames containing literal newlines are not supported in null mode
		# (astronomically rare in practice; would need per-file `file` calls to handle).
		tr '\0' '\n' \
			| file -F "$SEP" --mime-type -f - 2>/dev/null \
			| awk -v FS="$SEP" '{
				gsub(/^[ \t]+/, "", $2)
				print $2 FS $1
			}' \
			| sort -t"$SEP" -k1,1 $reverse \
			| awk -v FS="$SEP" '{printf "%s\0", $2}'
	else
		# Newline-delimited mode
		file -F "$SEP" --mime-type -f - 2>/dev/null \
			| awk -v FS="$SEP" '{
				# Trim leading whitespace from MIME type field
				gsub(/^[ \t]+/, "", $2)
				print $2 FS $1
			}' \
			| sort -t"$SEP" -k1,1 $reverse \
			| awk -v FS="$SEP" '{print $2}'
	fi
}

# Run if executed directly (not sourced)
if ! (return 0 2>/dev/null); then
	sort_by_mime "$@"
fi
