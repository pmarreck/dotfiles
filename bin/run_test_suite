#!/usr/bin/env bash

_run_test_suite_help() {
	cat <<'EOF'
Usage: run_test_suite [OPTIONS]

Discover and directly execute every *_test file in bin/test. Each test runs in
its own process. The exit status is the sum of failing test exit codes, capped
at 255 because process exit statuses are one byte.

Options:
	-h, --help       Show this help message
	--test           Run the runner's associated tests
	--test-dir DIR   Discover tests in DIR instead of bin/test

The compatibility command test_dotfiles invokes this same runner.
EOF
}

run_test_suite() {
	local script_dir
	local repo_root
	local test_dir
	local nullglob_was_set=false
	local noglob_was_set=false
	local test_files=()
	local test_file
	local test_name
	local status
	local summed_status=0
	local passed=0
	local failed=0
	local total
	local index=0

	script_dir="$(cd "$(dirname "${BASH_SOURCE[0]}")" && pwd -P)"
	repo_root="$(dirname "$script_dir")"
	test_dir="$script_dir/test"

	while (( $# > 0 )); do
		case "$1" in
			-h | --help)
				_run_test_suite_help
				return 0
				;;
			--test-dir)
				if (( $# < 2 )); then
					printf 'Error: --test-dir requires a directory.\n' >&2
					return 2
				fi
				test_dir="$2"
				shift 2
				;;
			*)
				printf 'Error: unknown option: %s\n' "$1" >&2
				_run_test_suite_help >&2
				return 2
				;;
		esac
	done

	if [[ ! -d "$test_dir" ]]; then
		printf 'Error: test directory not found: %s\n' "$test_dir" >&2
		return 2
	fi
	test_dir="$(cd "$test_dir" && pwd -P)"

	shopt -q nullglob && nullglob_was_set=true
	[[ "$-" == *f* ]] && noglob_was_set=true
	set +f
	shopt -s nullglob
	test_files=("$test_dir"/*_test)
	"$nullglob_was_set" || shopt -u nullglob
	"$noglob_was_set" && set -f

	total=${#test_files[@]}
	if (( total == 0 )); then
		printf 'Error: No test files found in %s.\n' "$test_dir" >&2
		return 2
	fi

	printf 'Running %s test files from %s\n' "$total" "$test_dir"
	for test_file in "${test_files[@]}"; do
		(( index++ ))
		test_name="${test_file##*/}"
		printf '\n[%s/%s] %s\n' "$index" "$total" "$test_name"

		if [[ ! -x "$test_file" ]]; then
			status=126
			printf 'FAIL %s: test file is not executable (exit %s)\n' "$test_name" "$status" >&2
		else
			if (cd "$repo_root" && "$test_file"); then
				status=0
			else
				status=$?
			fi
		fi

		if (( status == 0 )); then
			(( passed++ ))
			printf 'PASS %s\n' "$test_name"
		else
			(( failed++ ))
			(( summed_status += status ))
			if [[ -x "$test_file" ]]; then
				printf 'FAIL %s (exit %s)\n' "$test_name" "$status" >&2
			fi
		fi
	done

	if (( failed == 0 )); then
		printf '\nAll %s test files passed.\n' "$total"
		return 0
	fi

	printf '\n%s of %s test files failed; %s passed; summed exit status: %s.\n' \
		"$failed" "$total" "$passed" "$summed_status" >&2
	if (( summed_status > 255 )); then
		return 255
	fi
	return "$summed_status"
}

if ! (return 0 2>/dev/null); then
	if [[ "${1:-}" == '--test' ]]; then
		if (( $# != 1 )); then
			printf 'Error: --test does not accept arguments.\n' >&2
			exit 2
		fi
		test_file="$(dirname "${BASH_SOURCE[0]}")/test/run_test_suite_test"
		if [[ ! -x "$test_file" ]]; then
			printf 'Error: test file is missing or not executable: %s\n' "$test_file" >&2
			exit 1
		fi
		"$test_file" >/dev/null
		exit $?
	fi
	run_test_suite "$@"
	exit $?
fi
