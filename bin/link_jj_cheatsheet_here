#!/usr/bin/env bash
# link_jj_cheatsheet_here — symlink the jj cheatsheet into the CWD as
# jj_cheatsheet.md. Uses a RELATIVE link target (fleet policy: relative
# symlinks survive tree moves). Idempotent; refuses to clobber a real
# (non-symlink) file.
set -u

case "${1:-}" in
	-h|--help)
		echo "link_jj_cheatsheet_here - symlink the jj cheatsheet into the current directory as jj_cheatsheet.md"
		echo "Usage: cd <project> && link_jj_cheatsheet_here"
		exit 0 ;;
	--test)
		exec "$HOME/dotfiles/bin/test/link_jj_cheatsheet_here_test" >/dev/null ;;
esac

target="$HOME/dotfiles/docs/jj_reference/jj_cheatsheet.md"
link_name="jj_cheatsheet.md"

if [ ! -e "$target" ]; then
	echo "link_jj_cheatsheet_here: target not found: $target" >&2
	exit 1
fi
if [ -e "$link_name" ] && [ ! -L "$link_name" ]; then
	echo "link_jj_cheatsheet_here: $link_name exists and is not a symlink; refusing to clobber" >&2
	exit 1
fi

rel="$(realpath --relative-to=. "$target" 2>/dev/null || grealpath --relative-to=. "$target")"
ln -sfn "$rel" "$link_name"
