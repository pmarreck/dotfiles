#!/usr/bin/env bash

### png: convert images to PNG format

# ANSI color for warnings
YELLOW='\033[1;33m'
RESET='\033[0m'

warn_lossy() {
	echo -e "${YELLOW}Warning:${RESET} $1 is from a lossy source format." >&2
	echo -e "${YELLOW}  Converting lossy→lossless does not recover lost data, bloats file size, and accumulates artifacts on re-encoding.${RESET}" >&2
}

# Silence function
silence() {
	"$@" >/dev/null 2>&1
}

check_dependencies() {
	local missing_deps=()

	if ! silence command -v djxl; then
		missing_deps+=("djxl")
	fi

	if ! silence command -v magick; then
		missing_deps+=("ImageMagick")
	fi

	if ! silence command -v jxlinfo; then
		missing_deps+=("jxlinfo")
	fi

	# Determine which stat command to use
	if silence command -v gstat; then
		STAT="gstat"
	elif silence stat --version; then
		STAT="stat"
	else
		missing_deps+=("GNU stat (gstat)")
	fi
	export STAT

	if [[ ${#missing_deps[@]} -gt 0 ]]; then
		echo "Error: Missing required dependencies: ${missing_deps[*]}" >&2
		return 1
	fi

	return 0
}

declare -F debug >/dev/null 2>&1 || \
debug() {
	[ -n "$DEBUG" ] && echo "DEBUG: $*" >&2
}

print_help() {
	cat << 'EOF'
Usage: png [OPTIONS] FILES...

Convert images to PNG format. Supports JXL, JPEG, TIFF, WebP, HEIC, and more.

Options:
	--help, -h               Show this help message
	--about                  Show a brief description
	-f, --force              Overwrite existing output files without prompting
	--preserve-timestamps    Preserve original timestamps (default)
	--no-preserve-timestamps Do not preserve original timestamps
	--test                   Run self-test

Environment Variables:
	DEBUG                    Enable debug output

Examples:
	# Convert a JXL to PNG
	png image.jxl

	# Convert a JPEG to PNG (warns about lossy source)
	png photo.jpg

	# Convert multiple files
	png image1.jxl image2.tif photo.jpg

Notes:
	- Converting from lossy formats (JPEG, lossy JXL, WebP lossy) will emit a warning,
	  since converting lossy→lossless accumulates artifacts and wastes file size.
	- Lossless sources (JXL d=0, TIFF, PNG) convert cleanly.

Dependencies:
	- JPEG XL tools (djxl, jxlinfo)
	- ImageMagick (magick)
EOF
}

# Check if a JXL file was encoded losslessly from a truly lossless source
jxl_is_lossless() {
	local file="$1"
	local info
	info=$(jxlinfo "$file" 2>/dev/null)
	# If JPEG reconstruction data is present, the source was a lossy JPEG
	# even if the JXL encoding itself was lossless
	if echo "$info" | grep -q "JPEG bitstream reconstruction"; then
		return 1
	fi
	# jxlinfo reports "lossless" or "(possibly) lossless" for d=0
	# and "lossy" for d>0
	if echo "$info" | grep -q "lossless"; then
		return 0
	else
		return 1
	fi
}

# Known lossy source formats
is_lossy_format() {
	local ext="$1"
	case "$ext" in
		jpg|jpeg|webp|heic|heif) return 0 ;;
		*) return 1 ;;
	esac
}

process_file() {
	local file="$1"
	local preserve_timestamps="$2"
	local force="$3"

	if [[ ! -f "$file" ]]; then
		echo "Error: File not found: $file" >&2
		return 1
	fi

	local extension="${file##*.}"
	extension="${extension,,}"
	debug "Processing $file ($extension)..."

	# Already PNG
	if [[ "$extension" == "png" ]]; then
		debug "Skipping $file (already PNG)"
		echo "Skipping $file (already PNG)"
		return 0
	fi

	local output="${file%.*}.png"
	debug "Output file: $output"

	# Overwrite protection
	if [[ -f "$output" && "$force" != "true" ]]; then
		if [[ -t 0 && -t 1 ]]; then
			# Interactive terminal: prompt
			read -rp "Overwrite $output? [y/N] " answer
			if [[ "${answer,,}" != "y" ]]; then
				echo "Skipping $file (output exists)" >&2
				return 1
			fi
		else
			# Non-interactive: error
			echo "Error: $output already exists. Use -f/--force to overwrite." >&2
			return 1
		fi
	fi

	# Emit warnings for lossy sources
	if [[ "$extension" == "jxl" ]]; then
		if ! jxl_is_lossless "$file"; then
			warn_lossy "$file"
		fi
	elif is_lossy_format "$extension"; then
		warn_lossy "$file"
	fi

	# Convert
	if [[ "$extension" == "jxl" ]]; then
		debug "Converting JXL to PNG: $file -> $output"
		if ! djxl "$file" "$output" 2>/dev/null; then
			echo "Error converting $file to PNG." >&2
			return 1
		fi
	else
		# Everything else: pipe through ImageMagick
		debug "Converting $extension to PNG: $file -> $output"
		if ! magick "$file" png:"$output" 2>/dev/null; then
			echo "Error converting $file to PNG." >&2
			return 1
		fi
	fi

	# Post-processing
	if [[ "$preserve_timestamps" == "true" ]]; then
		debug "Preserving timestamps from $file to $output"
		touch -r "$file" "$output"
	fi

	if [[ -f "$output" ]]; then
		local original_size=$($STAT -c "%s" "$file")
		local new_size=$($STAT -c "%s" "$output")
		local original_display new_display
		if [[ "$original_size" -gt 5120 ]]; then
			original_display="$(( (original_size + 1023) / 1024 ))K"
		else
			original_display="${original_size}B"
		fi
		if [[ "$new_size" -gt 5120 ]]; then
			new_display="$(( (new_size + 1023) / 1024 ))K"
		else
			new_display="${new_size}B"
		fi
		echo "$file → $output (${original_display} → ${new_display})"
		return 0
	else
		echo "Error: Output file not produced for $file." >&2
		return 1
	fi
}

png() {
	check_dependencies || return 1

	local preserve_timestamps=true
	# Respect PRESERVE_TIMESTAMPS env var (unset/empty = true; 0/no/false = false)
	if [[ -n "$PRESERVE_TIMESTAMPS" ]]; then
		case "${PRESERVE_TIMESTAMPS,,}" in
			0|no|false) preserve_timestamps=false ;;
		esac
	fi
	local force=false
	local files=()

	while [[ $# -gt 0 ]]; do
		case "$1" in
			-h|--help) print_help; return 0 ;;
			--about) echo "png - Convert images to PNG format"; return 0 ;;
			--test)
				"$HOME/dotfiles/bin/test/png_test"
				return $?
				;;
			-f|--force) force=true ;;
			--preserve-timestamps) preserve_timestamps=true ;;
			--no-preserve-timestamps) preserve_timestamps=false ;;
			-*) echo "Unknown option: $1" >&2; print_help; return 1 ;;
			*) files+=("$1") ;;
		esac
		shift
	done

	if [[ ${#files[@]} -eq 0 ]]; then
		echo "Error: No input files specified" >&2
		print_help
		return 1
	fi

	local failures=0
	for file in "${files[@]}"; do
		if ! process_file "$file" "$preserve_timestamps" "$force"; then
			((failures++))
		fi
	done

	if [[ "$failures" -gt 0 ]]; then
		echo "Completed with $failures failures." >&2
		return 1
	fi

	return 0
}

# Run the function if this script is executed directly
if ! (return 0 2>/dev/null); then
	png "$@"
fi
