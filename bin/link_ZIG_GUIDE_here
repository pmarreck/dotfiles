#!/usr/bin/env bash
# link_ZIG_GUIDE_here — symlink the canonical Zig 0.16 API-changes guide into
# the CWD as ZIG_RECENT_API_CHANGES.md. Uses a RELATIVE link target (fleet
# policy: relative symlinks survive tree moves). Idempotent; refuses to clobber
# a real (non-symlink) file. Also removes the legacy 2025-named link.
set -u

case "${1:-}" in
	-h|--help)
		echo "link_ZIG_GUIDE_here - symlink the canonical Zig API-changes guide into the current directory as ZIG_RECENT_API_CHANGES.md"
		echo "Usage: cd <project> && link_ZIG_GUIDE_here    (requires \$CODE to be set)"
		exit 0 ;;
	--test)
		exec "$HOME/dotfiles/bin/test/link_ZIG_GUIDE_here_test" >/dev/null ;;
esac

if [ -z "${CODE:-}" ]; then
	echo "link_ZIG_GUIDE_here: CODE is not set or is empty" >&2
	exit 1
fi

target="$CODE/Obsidian Vaults/Peter Marreck/ZIG_RECENT_API_CHANGES.md"
link_name="ZIG_RECENT_API_CHANGES.md"

if [ ! -e "$target" ]; then
	echo "link_ZIG_GUIDE_here: target not found: $target" >&2
	exit 1
fi
if [ -e "$link_name" ] && [ ! -L "$link_name" ]; then
	echo "link_ZIG_GUIDE_here: $link_name exists and is not a symlink; refusing to clobber" >&2
	exit 1
fi

rm -f "ZIG_RECENT_API_CHANGES_2025.md"
rel="$(realpath --relative-to=. "$target" 2>/dev/null || grealpath --relative-to=. "$target")"
ln -sfn "$rel" "$link_name"
