#!/usr/bin/env bash

# bin/tac — wrapper preferring GNU tac (gtac) over any system tac.
#
# Why: this dotfiles environment assumes GNU tac semantics. On macOS there is
# no system tac at all; coreutils provides gtac, and we want scripts to keep
# saying 'tac'. On Linux /usr/bin/tac IS the GNU one — no warning fires.
#
# Design tension (we know): when gtac is unavailable, we fall back to the
# first non-self tac on PATH. If that fallback is non-GNU we warn to stderr
# in orange — the caller probably wants GNU semantics and will misbehave
# silently otherwise. Set MUTE_GNU_WRAPPER_WARNINGS=1 to suppress.
#
# Recursion guard: the function below resolves the wrapper's own canonical
# path and skips any fallback candidate whose readlink -f matches it — so
# the wrapper can't pick itself up via PATH lookup.

tac() {
	local self
	self=$(readlink -f "${BASH_SOURCE[0]}" 2>/dev/null) || self="${BASH_SOURCE[0]}"

	local whichtac
	# Prefer gtac (full path via type -P; gtac is never us)
	whichtac=$(type -P gtac 2>/dev/null)
	local is_gnu=1
	if [ -z "$whichtac" ]; then
		# No gtac — find the first tac on PATH whose canonical path isn't us
		local candidate canonical
		while IFS= read -r candidate; do
			[ -z "$candidate" ] && continue
			canonical=$(readlink -f "$candidate" 2>/dev/null) || canonical="$candidate"
			if [ "$canonical" != "$self" ]; then
				whichtac="$candidate"
				break
			fi
		done < <(type -aP tac 2>/dev/null)
		# Detect whether the fallback is GNU. GNU has `--version` and
		# prints "(GNU coreutils)"; BSD-flavored tools error out instead.
		is_gnu=0
		if [ -n "$whichtac" ] && "$whichtac" --version 2>/dev/null | grep -q GNU; then
			is_gnu=1
		fi
	fi
	if [ -z "$whichtac" ]; then
		echo "Error: Neither gtac nor a non-wrapper tac is available." >&2
		return 1
	fi
	if (( ! is_gnu )) && [ -z "$MUTE_GNU_WRAPPER_WARNINGS" ]; then
		printf '\033[38;5;208mwarning: bin/tac is using non-GNU tac (%s); GNU semantics may not apply\033[0m\n' "$whichtac" >&2
	fi
	"$whichtac" "$@"
}

# Run the function if this script is executed directly
if ! (return 0 2>/dev/null); then
	# Check if we are running tests
	if [ "$1" = "--test" ]; then
		# Run tests from the test file
		_test_file="$HOME/dotfiles/bin/test/$(basename "${0##\-}")_test"
		if [ -f "$_test_file" ]; then . "$_test_file" > /dev/null; fi
	else
		# If called directly, pass all arguments to the function
		$(basename "${0##\-}") "$@"
	fi
fi
