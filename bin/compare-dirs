#!/usr/bin/env luajit

local ABOUT = "Compare two directory trees and report all differences"

local function print_help()
	io.write([[Usage: compare-dirs [OPTIONS] <dir1> <dir2>

Compare two directory trees and report differences in content,
metadata, filenames (renames), and extended attributes.

Options:
  -h, --help           Show this help text
  --about              One-line description
  --test               Run associated tests
  --follow-symlinks    Follow symbolic links (default: don't follow)

Exit codes:
  0  No differences found
  1  Differences found
  2  Error (bad arguments, unreadable directories)
]])
end

-- Parse arguments
local follow_symlinks = false
local dirs = {}

local i = 1
while i <= #arg do
	local a = arg[i]
	if a == "-h" or a == "--help" then
		print_help()
		os.exit(0)
	elseif a == "--about" then
		print(ABOUT)
		os.exit(0)
	elseif a == "--test" then
		local test_file = os.getenv("HOME") .. "/dotfiles/bin/test/compare_dirs_test"
		local ok = os.execute(test_file .. " >/dev/null")
		if type(ok) == "number" then
			os.exit(ok)
		else
			os.exit(ok and 0 or 1)
		end
	elseif a == "--follow-symlinks" then
		follow_symlinks = true
	elseif a:sub(1, 1) == "-" then
		io.stderr:write("Unknown option: " .. a .. "\n")
		print_help()
		os.exit(2)
	else
		dirs[#dirs + 1] = a
	end
	i = i + 1
end

if #dirs ~= 2 then
	io.stderr:write("Error: exactly 2 directory paths required\n")
	os.exit(2)
end

local dir1, dir2 = dirs[1], dirs[2]

local ffi = require("ffi")
local bit = require("bit")

-- Platform detection
local IS_MAC = ffi.os == "OSX"
local IS_LINUX = ffi.os == "Linux"

-- Common C definitions
ffi.cdef([[
	long readlink(const char *path, char *buf, size_t bufsiz);
	char *strerror(int errnum);
]])

if IS_MAC then
	ffi.cdef([[
		struct passwd { char *pw_name; char *pw_passwd; uint32_t pw_uid; uint32_t pw_gid; long pw_change; char *pw_class; char *pw_gecos; char *pw_dir; char *pw_shell; long pw_expire; int pw_fields; };
		struct group { char *gr_name; char *gr_passwd; uint32_t gr_gid; char **gr_mem; };
		struct passwd *getpwuid(uint32_t uid);
		struct group *getgrgid(uint32_t gid);
		struct timespec { long tv_sec; long tv_nsec; };
		struct stat {
			int32_t   st_dev;
			uint16_t  st_mode;
			uint16_t  st_nlink;
			uint64_t  st_ino;
			uint32_t  st_uid;
			uint32_t  st_gid;
			int32_t   st_rdev;
			struct timespec st_atimespec;
			struct timespec st_mtimespec;
			struct timespec st_ctimespec;
			struct timespec st_birthtimespec;
			int64_t   st_size;
			int64_t   st_blocks;
			int32_t   st_blksize;
			uint32_t  st_flags;
			uint32_t  st_gen;
			int32_t   st_lspare;
			int64_t   st_qspare[2];
		};
		typedef struct { int __dummy; } DIR;
		struct dirent {
			uint64_t d_ino;
			uint64_t d_seekoff;
			uint16_t d_reclen;
			uint16_t d_namlen;
			uint8_t  d_type;
			char     d_name[1024];
		};
	]])
elseif IS_LINUX then
	ffi.cdef([[
		struct passwd { char *pw_name; char *pw_passwd; uint32_t pw_uid; uint32_t pw_gid; char *pw_gecos; char *pw_dir; char *pw_shell; };
		struct group { char *gr_name; char *gr_passwd; uint32_t gr_gid; char **gr_mem; };
		struct passwd *getpwuid(uint32_t uid);
		struct group *getgrgid(uint32_t gid);
		struct timespec { long tv_sec; long tv_nsec; };
		struct stat {
			uint64_t  st_dev;
			uint64_t  st_ino;
			uint64_t  st_nlink;
			uint32_t  st_mode;
			uint32_t  st_uid;
			uint32_t  st_gid;
			uint32_t  __pad0;
			uint64_t  st_rdev;
			int64_t   st_size;
			int64_t   st_blksize;
			int64_t   st_blocks;
			struct timespec st_atim;
			struct timespec st_mtim;
			struct timespec st_ctim;
			long      __unused[3];
		};
		typedef struct { int __dummy; } DIR;
		struct dirent {
			uint64_t d_ino;
			int64_t  d_off;
			uint16_t d_reclen;
			uint8_t  d_type;
			char     d_name[256];
		};
	]])
else
	io.stderr:write("Error: unsupported platform: " .. ffi.os .. "\n")
	os.exit(2)
end

ffi.cdef([[
	int lstat(const char *path, struct stat *buf);
	int stat(const char *path, struct stat *buf);
	DIR *opendir(const char *name);
	struct dirent *readdir(DIR *dirp);
	int closedir(DIR *dirp);
]])

-- SHA256 via CommonCrypto (macOS) or libcrypto (Linux)
local crypto_lib
if IS_MAC then
	ffi.cdef([[
		typedef unsigned int CC_LONG;
		typedef struct {
			uint32_t state[8];
			uint64_t count;
			unsigned char buffer[64];
		} CC_SHA256_CTX;
		int CC_SHA256_Init(CC_SHA256_CTX *c);
		int CC_SHA256_Update(CC_SHA256_CTX *c, const void *data, CC_LONG len);
		int CC_SHA256_Final(unsigned char *md, CC_SHA256_CTX *c);
	]])
else
	local ok, lib = pcall(ffi.load, "crypto")
	if not ok then
		io.stderr:write("Error: libcrypto not found. Install openssl.\n")
		os.exit(2)
	end
	crypto_lib = lib
	ffi.cdef([[
		typedef struct {
			uint32_t h[8];
			uint32_t Nl, Nh;
			uint32_t data[16];
			unsigned int num, md_len;
		} SHA256_CTX;
		int SHA256_Init(SHA256_CTX *c);
		int SHA256_Update(SHA256_CTX *c, const void *data, size_t len);
		int SHA256_Final(unsigned char *md, SHA256_CTX *c);
	]])
end

-- Constants
local S_IFMT  = 0xF000
local S_IFREG = 0x8000
local S_IFDIR = 0x4000
local S_IFLNK = 0xA000
local CHUNK_SIZE = 1048576 -- 1MB

-- Helper functions
local function get_errno_string()
	return ffi.string(ffi.C.strerror(ffi.errno()))
end

local function get_stat_mtime(st)
	if IS_MAC then return tonumber(st.st_mtimespec.tv_sec)
	else return tonumber(st.st_mtim.tv_sec) end
end

local function get_stat_ctime(st)
	if IS_MAC then return tonumber(st.st_ctimespec.tv_sec)
	else return tonumber(st.st_ctim.tv_sec) end
end

local function uid_to_name(uid)
	local pw = ffi.C.getpwuid(uid)
	if pw ~= nil then return ffi.string(pw.pw_name) end
	return tostring(uid)
end

local function gid_to_name(gid)
	local gr = ffi.C.getgrgid(gid)
	if gr ~= nil then return ffi.string(gr.gr_name) end
	return tostring(gid)
end

local function read_symlink(path)
	local buf = ffi.new("char[4096]")
	local len = tonumber(ffi.C.readlink(path, buf, 4096))
	if len < 0 then return nil end
	return ffi.string(buf, len)
end

local function file_type_from_mode(mode)
	local fmt = bit.band(mode, S_IFMT)
	if fmt == S_IFREG then return "file"
	elseif fmt == S_IFDIR then return "dir"
	elseif fmt == S_IFLNK then return "symlink"
	else return "other" end
end

local stat_func = follow_symlinks and ffi.C.stat or ffi.C.lstat

-- SHA256 functions
local function sha256_file(path)
	local f = io.open(path, "rb")
	if not f then return nil end
	local hash_buf = ffi.new("unsigned char[32]")
	if IS_MAC then
		local ctx = ffi.new("CC_SHA256_CTX")
		ffi.C.CC_SHA256_Init(ctx)
		while true do
			local chunk = f:read(CHUNK_SIZE)
			if not chunk then break end
			ffi.C.CC_SHA256_Update(ctx, chunk, #chunk)
		end
		ffi.C.CC_SHA256_Final(hash_buf, ctx)
	else
		local ctx = ffi.new("SHA256_CTX")
		crypto_lib.SHA256_Init(ctx)
		while true do
			local chunk = f:read(CHUNK_SIZE)
			if not chunk then break end
			crypto_lib.SHA256_Update(ctx, chunk, #chunk)
		end
		crypto_lib.SHA256_Final(hash_buf, ctx)
	end
	f:close()
	local hex = {}
	for j = 0, 31 do hex[#hex + 1] = string.format("%02x", hash_buf[j]) end
	return table.concat(hex)
end

local function sha256_string(s)
	local hash_buf = ffi.new("unsigned char[32]")
	if IS_MAC then
		local ctx = ffi.new("CC_SHA256_CTX")
		ffi.C.CC_SHA256_Init(ctx)
		ffi.C.CC_SHA256_Update(ctx, s, #s)
		ffi.C.CC_SHA256_Final(hash_buf, ctx)
	else
		local ctx = ffi.new("SHA256_CTX")
		crypto_lib.SHA256_Init(ctx)
		crypto_lib.SHA256_Update(ctx, s, #s)
		crypto_lib.SHA256_Final(hash_buf, ctx)
	end
	local hex = {}
	for j = 0, 31 do hex[#hex + 1] = string.format("%02x", hash_buf[j]) end
	return table.concat(hex)
end

-- xattr FFI
if IS_MAC then
	ffi.cdef([[
		long listxattr(const char *path, char *namebuf, size_t size, int options);
		long getxattr(const char *path, const char *name, void *value, size_t size, uint32_t position, int options);
	]])
else
	ffi.cdef([[
		long listxattr(const char *path, char *namebuf, size_t size);
		long getxattr(const char *path, const char *name, void *value, size_t size);
	]])
end

local function list_xattrs(path)
	local size
	if IS_MAC then
		size = tonumber(ffi.C.listxattr(path, nil, 0, 0))
	else
		size = tonumber(ffi.C.listxattr(path, nil, 0))
	end
	if not size or size <= 0 then return {} end

	local buf = ffi.new("char[?]", size)
	if IS_MAC then
		ffi.C.listxattr(path, buf, size, 0)
	else
		ffi.C.listxattr(path, buf, size)
	end

	local names = {}
	local start = 0
	for i = 0, size - 1 do
		if buf[i] == 0 then
			local name = ffi.string(buf + start, i - start)
			if #name > 0 then names[#names + 1] = name end
			start = i + 1
		end
	end
	table.sort(names)
	return names
end

local function get_xattr(path, name)
	local size
	if IS_MAC then
		size = tonumber(ffi.C.getxattr(path, name, nil, 0, 0, 0))
	else
		size = tonumber(ffi.C.getxattr(path, name, nil, 0))
	end
	if not size or size < 0 then return nil end
	if size == 0 then return "" end

	local buf = ffi.new("char[?]", size)
	if IS_MAC then
		ffi.C.getxattr(path, name, buf, size, 0, 0)
	else
		ffi.C.getxattr(path, name, buf, size)
	end
	return ffi.string(buf, size)
end

local function collect_xattrs(path)
	local names = list_xattrs(path)
	if #names == 0 then return {}, nil end
	local parts = {}
	for _, name in ipairs(names) do
		local val = get_xattr(path, name) or ""
		parts[#parts + 1] = name .. "=" .. val
	end
	local content_hash = sha256_string(table.concat(parts, "\0"))
	return names, content_hash
end

-- Validate directories exist (using stat)
local st_check = ffi.new("struct stat")
for _, d in ipairs({dir1, dir2}) do
	if ffi.C.stat(d, st_check) ~= 0 then
		io.stderr:write("Error: cannot access '" .. d .. "': " .. get_errno_string() .. "\n")
		os.exit(2)
	end
	if file_type_from_mode(st_check.st_mode) ~= "dir" then
		io.stderr:write("Error: not a directory: '" .. d .. "'\n")
		os.exit(2)
	end
end

-- Walk a directory tree, return map of relative_path -> record
local function walk_dir(base_path)
	local entries = {}
	local visited_dirs = {} -- dev:ino cycle detection for --follow-symlinks

	local function walk(rel_prefix)
		local full = base_path
		if rel_prefix ~= "" then full = base_path .. "/" .. rel_prefix end

		local dir = ffi.C.opendir(full)
		if dir == nil then
			io.stderr:write("WARNING: cannot open directory: " .. full .. ": " .. get_errno_string() .. "\n")
			return
		end

		while true do
			local ent = ffi.C.readdir(dir)
			if ent == nil then break end
			local name = ffi.string(ent.d_name)
			if name ~= "." and name ~= ".." then
				local rel_path = (rel_prefix == "") and name or (rel_prefix .. "/" .. name)
				local full_path = base_path .. "/" .. rel_path

				local st = ffi.new("struct stat")
				if stat_func(full_path, st) == 0 then
					local mode = tonumber(st.st_mode)
					local ftype = file_type_from_mode(mode)

					local rec = {
						type = ftype,
						size = tonumber(st.st_size),
						uid = tonumber(st.st_uid),
						gid = tonumber(st.st_gid),
						owner = uid_to_name(st.st_uid),
						group = gid_to_name(st.st_gid),
						mode = bit.band(mode, tonumber(0x1FF)),
						mtime = get_stat_mtime(st),
						ctime = get_stat_ctime(st),
						content_sha256 = nil,
						xattr_keys = {},
						xattr_content_hash = nil,
						symlink_target = nil,
					}

					-- Always read symlink target (readlink only succeeds on actual symlinks)
					local link_target = read_symlink(full_path)
					if link_target then
						rec.symlink_target = link_target
					end

					if ftype == "file" then
						rec.content_sha256 = sha256_file(full_path)
					end

					-- Collect xattrs
					rec.xattr_keys, rec.xattr_content_hash = collect_xattrs(full_path)

					entries[rel_path] = rec

					-- Recurse into directories (with cycle detection)
					if ftype == "dir" then
						local dev_ino = tonumber(st.st_dev) .. ":" .. tonumber(st.st_ino)
						if not visited_dirs[dev_ino] then
							visited_dirs[dev_ino] = true
							walk(rel_path)
						end
					end
				else
					io.stderr:write("WARNING: cannot stat: " .. full_path .. ": " .. get_errno_string() .. "\n")
				end
			end
		end

		ffi.C.closedir(dir)
	end

	walk("")
	return entries
end

-- Collect
local entries1 = walk_dir(dir1)
local entries2 = walk_dir(dir2)

-- Diff engine
local diffs = {}
local only1 = {}
local only2 = {}
local renames = {}

local all_paths = {}
for p in pairs(entries1) do all_paths[p] = true end
for p in pairs(entries2) do all_paths[p] = true end

local unmatched1 = {}
local unmatched2 = {}

for p in pairs(all_paths) do
	local e1 = entries1[p]
	local e2 = entries2[p]
	if e1 and e2 then
		-- Compare content
		if e1.content_sha256 and e2.content_sha256 and e1.content_sha256 ~= e2.content_sha256 then
			diffs[#diffs + 1] = {path = p, field = "content", val1 = e1.content_sha256:sub(1, 16), val2 = e2.content_sha256:sub(1, 16)}
		end
		-- Compare metadata
		if e1.size ~= e2.size then
			diffs[#diffs + 1] = {path = p, field = "size", val1 = tostring(e1.size), val2 = tostring(e2.size)}
		end
		if e1.mode ~= e2.mode then
			diffs[#diffs + 1] = {path = p, field = "mode", val1 = string.format("%04o", e1.mode), val2 = string.format("%04o", e2.mode)}
		end
		if e1.owner ~= e2.owner then
			diffs[#diffs + 1] = {path = p, field = "owner", val1 = e1.owner, val2 = e2.owner}
		end
		if e1.group ~= e2.group then
			diffs[#diffs + 1] = {path = p, field = "group", val1 = e1.group, val2 = e2.group}
		end
		if e1.mtime ~= e2.mtime then
			diffs[#diffs + 1] = {path = p, field = "mtime", val1 = os.date("%Y-%m-%d %H:%M:%S", e1.mtime), val2 = os.date("%Y-%m-%d %H:%M:%S", e2.mtime)}
		end
		if e1.ctime ~= e2.ctime then
			diffs[#diffs + 1] = {path = p, field = "ctime", val1 = os.date("%Y-%m-%d %H:%M:%S", e1.ctime), val2 = os.date("%Y-%m-%d %H:%M:%S", e2.ctime)}
		end
		-- Symlink target
		if e1.symlink_target ~= e2.symlink_target then
			if e1.symlink_target or e2.symlink_target then
				diffs[#diffs + 1] = {path = p, field = "symlink_target", val1 = e1.symlink_target or "(none)", val2 = e2.symlink_target or "(none)"}
			end
		end
		-- xattr differences
		local keys1_set, keys2_set = {}, {}
		for _, k in ipairs(e1.xattr_keys or {}) do keys1_set[k] = true end
		for _, k in ipairs(e2.xattr_keys or {}) do keys2_set[k] = true end
		local all_xattr_keys = {}
		for k in pairs(keys1_set) do all_xattr_keys[k] = true end
		for k in pairs(keys2_set) do all_xattr_keys[k] = true end
		local sorted_xkeys = {}
		for k in pairs(all_xattr_keys) do sorted_xkeys[#sorted_xkeys + 1] = k end
		table.sort(sorted_xkeys)
		for _, k in ipairs(sorted_xkeys) do
			if keys1_set[k] and not keys2_set[k] then
				diffs[#diffs + 1] = {path = p, field = "xattr:" .. k, val1 = "(present)", val2 = "(absent)"}
			elseif keys2_set[k] and not keys1_set[k] then
				diffs[#diffs + 1] = {path = p, field = "xattr:" .. k, val1 = "(absent)", val2 = "(present)"}
			end
		end
		if e1.xattr_content_hash and e2.xattr_content_hash and e1.xattr_content_hash ~= e2.xattr_content_hash then
			local has_key_diff = false
			for _, k in ipairs(sorted_xkeys) do
				if keys1_set[k] ~= keys2_set[k] then has_key_diff = true; break end
			end
			if not has_key_diff then
				diffs[#diffs + 1] = {path = p, field = "xattr_hash", val1 = e1.xattr_content_hash:sub(1, 16), val2 = e2.xattr_content_hash:sub(1, 16)}
			end
		end
	elseif e1 and not e2 then
		if e1.content_sha256 then
			unmatched1[p] = e1.content_sha256
		else
			only1[#only1 + 1] = {path = p, type = e1.type}
		end
	elseif e2 and not e1 then
		if e2.content_sha256 then
			unmatched2[p] = e2.content_sha256
		else
			only2[#only2 + 1] = {path = p, type = e2.type}
		end
	end
end

-- Rename detection
local hash_to_paths1 = {}
for p, h in pairs(unmatched1) do
	if not hash_to_paths1[h] then hash_to_paths1[h] = {} end
	hash_to_paths1[h][#hash_to_paths1[h] + 1] = p
end
local hash_to_paths2 = {}
for p, h in pairs(unmatched2) do
	if not hash_to_paths2[h] then hash_to_paths2[h] = {} end
	hash_to_paths2[h][#hash_to_paths2[h] + 1] = p
end

local matched1 = {}
local matched2 = {}

for h, paths1 in pairs(hash_to_paths1) do
	local paths2 = hash_to_paths2[h]
	if paths2 then
		table.sort(paths1)
		table.sort(paths2)
		local used1, used2 = {}, {}
		for _, p1 in ipairs(paths1) do
			local base1 = p1:match("[^/]+$")
			for _, p2 in ipairs(paths2) do
				if not used2[p2] then
					local base2 = p2:match("[^/]+$")
					if base1 == base2 then
						renames[#renames + 1] = {path1 = p1, path2 = p2, hash = h:sub(1, 16)}
						used1[p1] = true
						used2[p2] = true
						matched1[p1] = true
						matched2[p2] = true
						break
					end
				end
			end
		end
		local rem1, rem2 = {}, {}
		for _, p in ipairs(paths1) do if not used1[p] then rem1[#rem1 + 1] = p end end
		for _, p in ipairs(paths2) do if not used2[p] then rem2[#rem2 + 1] = p end end
		for j = 1, math.min(#rem1, #rem2) do
			renames[#renames + 1] = {path1 = rem1[j], path2 = rem2[j], hash = h:sub(1, 16)}
			matched1[rem1[j]] = true
			matched2[rem2[j]] = true
		end
	end
end

-- Remaining unmatched files go to only1/only2
for p in pairs(unmatched1) do
	if not matched1[p] then only1[#only1 + 1] = {path = p, type = "file"} end
end
for p in pairs(unmatched2) do
	if not matched2[p] then only2[#only2 + 1] = {path = p, type = "file"} end
end

table.sort(only1, function(a, b) return a.path < b.path end)
table.sort(only2, function(a, b) return a.path < b.path end)
table.sort(renames, function(a, b) return a.path1 < b.path1 end)
table.sort(diffs, function(a, b)
	if a.path ~= b.path then return a.path < b.path end
	local order = {content=1, size=2, mode=3, owner=4, group=5, mtime=6, ctime=7, symlink_target=8, xattr_hash=100}
	local oa = order[a.field] or (a.field:match("^xattr:") and 50 or 99)
	local ob = order[b.field] or (b.field:match("^xattr:") and 50 or 99)
	if oa ~= ob then return oa < ob end
	return a.field < b.field
end)

-- Output formatter
local has_output = false

local function print_section(title)
	if has_output then io.write("\n") end
	io.write("=== " .. title .. " ===\n")
	has_output = true
end

local function pad(s, w)
	if #s >= w then return s end
	return s .. string.rep(" ", w - #s)
end

local function format_only_path(entry)
	if entry.type == "dir" then return entry.path .. "/" end
	return entry.path
end

-- Only in dir1
if #only1 > 0 then
	print_section("Only in " .. dir1)
	for _, e in ipairs(only1) do
		io.write("  " .. format_only_path(e) .. "\n")
	end
end

-- Only in dir2
if #only2 > 0 then
	print_section("Only in " .. dir2)
	for _, e in ipairs(only2) do
		io.write("  " .. format_only_path(e) .. "\n")
	end
end

-- Renames
if #renames > 0 then
	print_section("Renames")
	local w1, w2 = 9, 9
	for _, r in ipairs(renames) do
		w1 = math.max(w1, #r.path1)
		w2 = math.max(w2, #r.path2)
	end
	io.write("  " .. pad("Dir1 Path", w1) .. " | " .. pad("Dir2 Path", w2) .. " | SHA256 (first 16)\n")
	io.write("  " .. string.rep("-", w1) .. "-+-" .. string.rep("-", w2) .. "-+-" .. string.rep("-", 17) .. "\n")
	for _, r in ipairs(renames) do
		io.write("  " .. pad(r.path1, w1) .. " | " .. pad(r.path2, w2) .. " | " .. r.hash .. "\n")
	end
end

-- Differences
if #diffs > 0 then
	print_section("Differences")
	local wp, wf, w1, w2 = 4, 5, 4, 4
	for _, d in ipairs(diffs) do
		wp = math.max(wp, #d.path)
		wf = math.max(wf, #d.field)
		w1 = math.max(w1, #d.val1)
		w2 = math.max(w2, #d.val2)
	end
	io.write("  " .. pad("Path", wp) .. " | " .. pad("Field", wf) .. " | " .. pad("Dir1", w1) .. " | Dir2\n")
	io.write("  " .. string.rep("-", wp) .. "-+-" .. string.rep("-", wf) .. "-+-" .. string.rep("-", w1) .. "-+-" .. string.rep("-", w2) .. "\n")
	for _, d in ipairs(diffs) do
		io.write("  " .. pad(d.path, wp) .. " | " .. pad(d.field, wf) .. " | " .. pad(d.val1, w1) .. " | " .. d.val2 .. "\n")
	end
end

os.exit(has_output and 1 or 0)
