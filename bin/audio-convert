#!/usr/bin/env bash
# audio-convert: convert audio files between formats with safety warnings.
# Usage: audio-convert -f FORMAT file [file ...]
# Or invoke via aliases: mp3, aac, m4a, flac, alac

print_about() {
	local cmd="$1"
	case "$cmd" in
		mp3)          echo "mp3 - Convert audio files to MP3 (ffmpeg wrapper with lossy/lossless safety rules)" ;;
		aac)          echo "aac - Convert audio files to AAC-in-M4A (ffmpeg wrapper with lossy/lossless safety rules)" ;;
		m4a)          echo "m4a - Alias for aac; converts audio files to AAC-in-M4A" ;;
		flac)         echo "flac - Convert audio files to FLAC lossless (ffmpeg wrapper with lossy/lossless safety rules)" ;;
		alac)         echo "alac - Convert audio files to ALAC-in-M4A lossless (ffmpeg wrapper with lossy/lossless safety rules)" ;;
		*)            echo "audio-convert - Audio format converter (use -f/--format, or invoke via mp3/aac/m4a/flac/alac aliases)" ;;
	esac
}

print_help() {
	local cmd="$1"
	cat <<EOF
Usage: $cmd [OPTIONS] FILE [FILE ...]

Convert audio files, enforcing lossy/lossless safety rules via ffprobe codec detection.

Options:
	-h, --help                 Show this help
	--about                    One-line summary
	--test                     Run the test suite
	-f, --format=FMT           Target format: mp3|aac|m4a|flac|alac
	                           Required when invoked as 'audio-convert'.
	                           With an alias, overrides the alias and warns.
	--force                    Overwrite existing output files
	--preserve-timestamps      Copy source mtime to output (default)
	--no-preserve-timestamps   Do not copy source mtime
	--bitrate=N                (mp3,aac) Output bitrate in kbps
	--vbr[=N]                  (mp3 only) VBR mode, optional quality 0-9 (0=best)
	--title=STR                Write title metadata (default: no metadata)
	--artist=STR               Write artist metadata
	--album=STR                Write album metadata
	--albumartist=STR          Write album-artist metadata
	--year=STR, --date=STR     Write year/date metadata (synonyms)
	--track=STR                Write track metadata
	--genre=STR                Write genre metadata
	--comment=STR              Write comment metadata
	--composer=STR             Write composer metadata

Environment:
	PRESERVE_TIMESTAMPS=false  Disable timestamp preservation (CLI flag wins)

Conversion matrix:
	lossless -> lossless   silent
	lossless -> lossy      warn
	lossy    -> lossy      warn (double artifact generation)
	lossy    -> lossless   ERROR (damage already done; no advantage)
	same codec as target   ERROR (already that format)

Examples:
	mp3 song.wav
	flac recording.aiff
	aac --bitrate=192 song.wav
	mp3 --vbr=0 --title="Foo" song.wav
EOF
}

check_dependencies() {
	local missing=()
	command -v ffmpeg  >/dev/null 2>&1 || missing+=("ffmpeg")
	command -v ffprobe >/dev/null 2>&1 || missing+=("ffprobe")
	if [[ ${#missing[@]} -gt 0 ]]; then
		local joined
		printf -v joined '%s, ' "${missing[@]}"
		joined="${joined%, }"
		echo "Error: ${joined} not found on PATH." >&2
		echo "  Install with: nix profile install nixpkgs#ffmpeg" >&2
		return 1
	fi
	return 0
}

probe_codec() {
	local file="$1"
	if [[ ! -f "$file" ]]; then
		echo "Error: file not found: $file" >&2
		return 1
	fi
	local codec
	codec=$(ffprobe -v error -select_streams a:0 \
		-show_entries stream=codec_name \
		-of default=nw=1:nk=1 "$file" 2>/dev/null)
	if [[ -z "$codec" ]]; then
		echo "Error: could not determine audio codec for $file" >&2
		return 1
	fi
	echo "$codec"
}

codec_class() {
	local codec="$1"
	case "$codec" in
		pcm_*|flac|alac|wmalossless) echo "lossless" ;;
		mp3|aac|vorbis|opus|wma*) echo "lossy" ;;
		*) echo "unknown" ;;
	esac
}

# Returns 0 if conversion should proceed, 1 if it should be refused.
# Prints appropriate warning to stderr when proceeding is noisy.
apply_matrix() {
	local src_codec="$1"
	local target_codec="$2"
	local file="$3"

	if [[ "$src_codec" == "$target_codec" ]]; then
		echo "Error: $file is already $target_codec; refusing to convert to same codec." >&2
		return 1
	fi

	local src_class target_class
	src_class=$(codec_class "$src_codec")
	target_class=$(codec_class "$target_codec")

	if [[ "$src_class" == "unknown" ]]; then
		echo "Error: unrecognized source codec '$src_codec' for $file" >&2
		return 1
	fi
	if [[ "$target_class" == "unknown" ]]; then
		echo "Error: unrecognized target codec '$target_codec' (internal bug?)" >&2
		return 1
	fi

	if [[ "$src_class" == "lossy" && "$target_class" == "lossless" ]]; then
		echo "Error: refusing lossy -> lossless conversion for $file" >&2
		echo "  The damage already done by lossy compression cannot be undone;" >&2
		echo "  re-encoding to a lossless format only inflates file size." >&2
		return 1
	fi

	if [[ "$src_class" == "lossy" && "$target_class" == "lossy" ]]; then
		echo "Warning: converting lossy ($src_codec) to lossy ($target_codec) for $file" >&2
		echo "  This compounds lossy compression artifacts. Prefer the original source." >&2
	fi

	if [[ "$src_class" == "lossless" && "$target_class" == "lossy" ]]; then
		echo "Warning: converting lossless ($src_codec) to lossy ($target_codec) for $file" >&2
		echo "  This causes data loss. Keep the original if you might want full quality later." >&2
	fi

	return 0
}


# output_path INPUT TARGET-NAME -> prints the output file path
output_path() {
	local input="$1"
	local target="$2"
	local ext
	case "$target" in
		mp3)          ext="mp3" ;;
		aac|m4a|alac) ext="m4a" ;;
		flac)         ext="flac" ;;
		*) echo "Error: unknown target '$target' in output_path" >&2; return 1 ;;
	esac
	echo "${input%.*}.$ext"
}


# Invoke ffmpeg for a single file. Target selects codec+container.
# Usage: run_ffmpeg INPUT OUTPUT TARGET BITRATE VBR [METADATA_ARGS...]
#   BITRATE - kbps, used when VBR is empty (CBR mode) for mp3/aac
#   VBR     - empty for CBR mode; numeric level 0-9 for mp3 VBR
#   METADATA_ARGS... - alternating -metadata key=value pairs (may be empty)
run_ffmpeg() {
	local input="$1"
	local output="$2"
	local target="$3"
	local bitrate="$4"
	local vbr="$5"
	shift 5
	local -a metadata_args=("$@")

	local -a codec_arr
	case "$target" in
		mp3)
			if [[ -n "$vbr" ]]; then
				codec_arr=(-c:a libmp3lame -q:a "$vbr")
			else
				codec_arr=(-c:a libmp3lame -b:a "${bitrate}k")
			fi
			;;
		aac)
			codec_arr=(-c:a aac -b:a "${bitrate}k")
			;;
		flac) codec_arr=(-c:a flac -compression_level 8) ;;
		alac) codec_arr=(-c:a alac) ;;
		*) echo "Error: unsupported target '$target' in run_ffmpeg" >&2; return 1 ;;
	esac

	local -a extra_args=()
	case "$target" in
		aac|alac) extra_args+=("-movflags" "+faststart") ;;
		mp3)      extra_args+=("-write_id3v2" "1") ;;
	esac

	ffmpeg -hide_banner -loglevel error -nostdin -y \
		-i "$input" -map 0:a \
		"${codec_arr[@]}" \
		-map_metadata -1 \
		"${metadata_args[@]}" \
		"${extra_args[@]}" \
		"$output"
}


# Pretty-print a conversion result: "input → output (newsize, pct% of original)"
print_result() {
	local input="$1"
	local output="$2"
	local orig_size new_size
	orig_size=$(wc -c < "$input" 2>/dev/null | tr -d ' ')
	new_size=$(wc -c < "$output" 2>/dev/null | tr -d ' ')
	if [[ -z "$orig_size" || "$orig_size" -eq 0 ]]; then
		echo "$input → $output ($new_size bytes)"
		return
	fi
	local pct
	pct=$(awk -v n="$new_size" -v o="$orig_size" 'BEGIN { printf "%.1f", (n * 100) / o }')
	# Prefer GNU numfmt if available for human-readable sizes
	local orig_disp="$orig_size" new_disp="$new_size"
	if command -v gnumfmt >/dev/null 2>&1; then
		orig_disp=$(echo "$orig_size" | gnumfmt --to=iec)
		new_disp=$(echo "$new_size" | gnumfmt --to=iec)
	elif command -v numfmt >/dev/null 2>&1 && numfmt --to=iec 1 >/dev/null 2>&1; then
		orig_disp=$(echo "$orig_size" | numfmt --to=iec)
		new_disp=$(echo "$new_size" | numfmt --to=iec)
	fi
	echo "$input → $output ($new_disp, ${pct}% of original)"
}


audio_convert() {
	local invoked_as
	invoked_as=$(basename "$0")
	case "$invoked_as" in
		bash|-bash|zsh|-zsh|sh|-sh) invoked_as="audio-convert" ;;
	esac

	local format_override=""
	local files=()
	local force=false
	local bitrate=""
	local vbr=""
	local -A metadata=()
	local preserve_timestamps=true
	# Respect env var first; CLI flags below override
	if [[ -n "${PRESERVE_TIMESTAMPS-}" ]]; then
		case "${PRESERVE_TIMESTAMPS,,}" in
			0|no|false) preserve_timestamps=false ;;
		esac
	fi

	while [[ $# -gt 0 ]]; do
		case "$1" in
			-h|--help) print_help "$invoked_as"; return 0 ;;
			--about)   print_about "$invoked_as"; return 0 ;;
			--test)
				"$HOME/dotfiles/bin/test/audio_convert_test"
				return $?
				;;
			-f|--format)
				shift
				if [[ $# -eq 0 || -z "$1" || "$1" == -* ]]; then
					echo "Error: -f/--format requires a format argument (mp3, aac, m4a, flac, alac)" >&2
					return 1
				fi
				format_override="$1"
				;;
			--format=*)
				format_override="${1#*=}"
				if [[ -z "$format_override" ]]; then
					echo "Error: --format= requires a value (mp3, aac, m4a, flac, alac)" >&2
					return 1
				fi
				;;
			--force) force=true ;;
			--bitrate=*)
				bitrate="${1#*=}"
				if ! [[ "$bitrate" =~ ^[0-9]+$ ]] || (( bitrate < 1 )); then
					echo "Error: --bitrate requires a positive integer (kbps)" >&2
					return 1
				fi
				;;
			--vbr) vbr="default" ;;
			--vbr=*)
				vbr="${1#*=}"
				if ! [[ "$vbr" =~ ^[0-9]+$ ]] || (( vbr > 9 )); then
					echo "Error: --vbr requires a number 0-9 (0=best quality)" >&2
					return 1
				fi
				;;
			--title=*)       metadata[title]="${1#*=}" ;;
			--artist=*)      metadata[artist]="${1#*=}" ;;
			--album=*)       metadata[album]="${1#*=}" ;;
			--albumartist=*) metadata[album_artist]="${1#*=}" ;;
			--year=*|--date=*) metadata[date]="${1#*=}" ;;
			--track=*)       metadata[track]="${1#*=}" ;;
			--genre=*)       metadata[genre]="${1#*=}" ;;
			--comment=*)     metadata[comment]="${1#*=}" ;;
			--composer=*)    metadata[composer]="${1#*=}" ;;
			--no-preserve-timestamps) preserve_timestamps=false ;;
			--preserve-timestamps)    preserve_timestamps=true ;;
			--) shift; while [[ $# -gt 0 ]]; do files+=("$1"); shift; done ;;
			-*) echo "Error: unknown option: $1" >&2; return 1 ;;
			*) files+=("$1") ;;
		esac
		shift
	done

	# Resolve target format from invocation name
	local target=""
	case "$invoked_as" in
		mp3|aac|m4a|flac|alac) target="$invoked_as" ;;
		audio-convert)
			if [[ -z "$format_override" ]]; then
				echo "Error: audio-convert requires -f/--format FMT (one of: mp3, aac, m4a, flac, alac)" >&2
				return 1
			fi
			;;
		*)
			echo "Error: unrecognized invocation name '$invoked_as' (expected one of: mp3, aac, m4a, flac, alac, audio-convert)" >&2
			return 1
			;;
	esac

	if [[ -n "$format_override" ]]; then
		case "$format_override" in
			mp3|aac|m4a|flac|alac) ;;
			*) echo "Error: invalid --format '$format_override' (must be: mp3, aac, m4a, flac, alac)" >&2; return 1 ;;
		esac
		if [[ -n "$target" && "$format_override" != "$target" ]]; then
			echo "Warning: --format=$format_override overrides alias $target" >&2
		fi
		target="$format_override"
	fi

	# Normalize m4a -> aac internally (m4a is an alias for aac codec)
	local codec_target="$target"
	case "$codec_target" in
		m4a) codec_target="aac" ;;
	esac

	check_dependencies || return 1

	# Validate mutual exclusion of --vbr and --bitrate (both user-provided)
	if [[ -n "$vbr" && -n "$bitrate" ]]; then
		echo "Error: --vbr and --bitrate are mutually exclusive" >&2
		return 1
	fi

	# --vbr only applies to mp3
	if [[ -n "$vbr" && "$codec_target" != "mp3" ]]; then
		echo "Error: --vbr is mp3 only (not supported for $codec_target)" >&2
		return 1
	fi

	# Apply defaults only when the user supplied neither --vbr nor --bitrate
	if [[ -z "$vbr" && -z "$bitrate" ]]; then
		case "$codec_target" in
			mp3) bitrate=192; echo "Using default bitrate for mp3: 192 kbps CBR" >&2 ;;
			aac) bitrate=128; echo "Using default bitrate for aac: 128 kbps CBR" >&2 ;;
		esac
	fi

	# Normalize vbr="default" -> numeric level 2 (lame -V 2 ≈ 190 kbps)
	if [[ "$vbr" == "default" ]]; then
		vbr="2"
	fi

	# Build metadata args from user-specified fields
	local -a metadata_args=()
	local mk
	for mk in "${!metadata[@]}"; do
		metadata_args+=("-metadata" "${mk}=${metadata[$mk]}")
	done

	if [[ ${#files[@]} -eq 0 ]]; then
		echo "Error: no input files" >&2
		return 1
	fi

	local failures=0
	for file in "${files[@]}"; do
		if [[ ! -f "$file" ]]; then
			echo "Error: file not found: $file" >&2
			(( failures++ ))
			continue
		fi
		local src_codec
		src_codec=$(probe_codec "$file") || { (( failures++ )); continue; }
		if ! apply_matrix "$src_codec" "$codec_target" "$file"; then
			(( failures++ ))
			continue
		fi
		local out
		out=$(output_path "$file" "$target") || { (( failures++ )); continue; }

		if [[ -e "$out" && "$force" != "true" ]]; then
			echo "Error: output already exists: $out (use --force to overwrite)" >&2
			(( failures++ ))
			continue
		fi

		if ! run_ffmpeg "$file" "$out" "$codec_target" "$bitrate" "$vbr" "${metadata_args[@]}"; then
			echo "Error: ffmpeg failed for $file" >&2
			(( failures++ ))
			continue
		fi
		if [[ "$preserve_timestamps" == "true" ]]; then
			touch -r "$file" "$out"
		fi
		print_result "$file" "$out"
	done
	return $failures
}

if ! (return 0 2>/dev/null); then
	audio_convert "$@"
fi
