#!/usr/bin/env bash


# Print out the names of all executables available in your PATH
executables() {
	[ -n "${EDIT}" ] && unset EDIT && edit_function "${FUNCNAME[0]}" "$BASH_SOURCE" && return

	local show_scripts=false
	local ambiguate=false
	local show_path=false
	local path_filters=()

	# Parse command line arguments
	while [[ $# -gt 0 ]]; do
		case "$1" in
			--scripts) show_scripts=true ; shift ;;
			--ambiguate) ambiguate=true ; shift ;;
			--path) show_path=true ; shift ;;
			-h|--help)
				echo "executables - Print out the names of all executables available in your PATH"
				echo ""
				echo "Usage: executables [OPTIONS] [PATH ...]"
				echo ""
				echo "OPTIONS:"
				echo "  --scripts      Only show script files"
				echo "  --ambiguate    Strip symlink annotations and deduplicate by name"
				echo "                 (useful for building autocomplete lists)"
				echo "  --path         Show full path in a second column (dim)"
				echo "                 For symlinks: source_path -> target_path"
				echo "  -h, --help     Show this help message"
				echo "  -a, --about    Show brief description"
				echo ""
				echo "If one or more PATH values are provided, results are limited to executables"
				echo "found within those directories."
				return 0 ;;
			-a|--about)
				echo "Print out the names of all executables available in your PATH"
				return 0 ;;
			*)
				if [[ -d "$1" ]]; then
					local resolved_path
					if ! resolved_path=$(cd "$1" 2>/dev/null && pwd -P); then
						warn "Unable to resolve path: $1" >&2
						return 1
					fi
					path_filters+=("$resolved_path")
					shift
				else
					warn "Unknown option or invalid path: $1" >&2
					return 1
				fi
				;;
		esac
	done

	local search_paths=()
	local nonexistent_paths=()

	# Process PATH into valid directories
	IFS=: read -ra path_dirs <<<"$PATH"
	for dir in "${path_dirs[@]}"; do
		if [[ -d "$dir" ]]; then
			search_paths+=("$dir")
		else
			nonexistent_paths+=("$dir")
		fi
	done

	if [[ ${#path_filters[@]} -gt 0 ]]; then
		local filtered_paths=()
		for dir in "${search_paths[@]}"; do
			local resolved_dir
			if ! resolved_dir=$(cd "$dir" 2>/dev/null && pwd -P); then
				continue
			fi
			for filter_path in "${path_filters[@]}"; do
				if [[ "$resolved_dir" == "$filter_path" || "$resolved_dir" == "$filter_path"/* ]]; then
					filtered_paths+=("$dir")
					break
				fi
			done
		done
		search_paths=("${filtered_paths[@]}")
	fi

	[[ ${#search_paths[@]} -eq 0 ]] && return 0

	# Resolve external command paths upfront so they work even with restricted PATHs
	local sort_cmd
	sort_cmd=$(command -v sort 2>/dev/null) || sort_cmd=/usr/bin/sort

	# Collect all candidate files, then process in a pipeline instead of per-file subshells.
	# Key optimizations:
	#   - ${exe##*/} instead of $(basename "$exe") — no subshell per file
	#   - Inline symlink check instead of function call overhead
	#   - For --scripts: batch file(1) via xargs instead of one invocation per file
	#   - Stream to sort -u instead of accumulating in a bash array

	# Format a single executable path into the desired output line.
	# Reads null-delimited paths from stdin, writes formatted lines to stdout.
	_format_output() {
		local dim=$'\033[2m'
		local reset=$'\033[0m'
		while IFS= read -r -d $'\0' exe; do
			[[ -z "$exe" ]] && continue
			local name="${exe##*/}"
			if $ambiguate; then
				printf '%s\n' "$name"
			elif $show_path; then
				if [[ -L "$exe" ]]; then
					local target
					target=$(readlink -f "$exe" 2>/dev/null) || target="?"
					printf '%s\t%s%s -> %s%s\n' "$name" "$dim" "$exe" "$target" "$reset"
				else
					printf '%s\t%s%s%s\n' "$name" "$dim" "$exe" "$reset"
				fi
			else
				[[ -L "$exe" ]] && name="$name (symlinked)"
				printf '%s\n' "$name"
			fi
		done
	}

	# For --path mode, align columns via two-pass: first collect, then pad
	_align_columns() {
		if $show_path; then
			local awk_cmd
			awk_cmd=$(command -v awk 2>/dev/null) || awk_cmd=/usr/bin/awk
			# Two-pass awk: first pass finds max name width, second aligns
			"$awk_cmd" -F'\t' '
				{ lines[NR] = $0; names[NR] = $1; paths[NR] = $2; count = NR }
				END {
					max = 0
					for (i = 1; i <= count; i++)
						if (length(names[i]) > max) max = length(names[i])
					for (i = 1; i <= count; i++)
						printf "%-" max "s  %s\n", names[i], paths[i]
				}
			'
		else
			# Passthrough: read line by line using bash builtins (no cat dependency)
			local line
			while IFS= read -r line; do
				printf '%s\n' "$line"
			done
		fi
	}

	if $show_scripts; then
		# --scripts mode: batch file(1) calls via xargs for massive speedup
		_executables_collect_candidates "${search_paths[@]}" \
			| xargs -0 file -L 2>/dev/null \
			| grep 'script' \
			| while IFS=: read -r exe _rest; do
				[[ -z "$exe" || ! -f "$exe" ]] && continue
				printf '%s\0' "$exe"
			done \
			| _format_output \
			| "$sort_cmd" -u \
			| _align_columns
	else
		# Normal mode: stream directly, no file(1) needed
		_executables_collect_candidates "${search_paths[@]}" \
			| _format_output \
			| "$sort_cmd" -u \
			| _align_columns
	fi

	# Show warnings if any
	if [[ ${#nonexistent_paths[@]} -gt 0 ]]; then
		for path in "${nonexistent_paths[@]}"; do
			note "Directory in PATH does not exist: $path"
		done
	fi
}

# Emit null-delimited paths of executable files/symlinks from given directories
_executables_collect_candidates() {
	local dirs=("$@")
	if command -v fd >/dev/null 2>&1; then
		local search_path_args=()
		for path in "${dirs[@]}"; do
			search_path_args+=(--search-path "$path")
		done
		# fd with --type x filters for executable permission natively
		fd --max-depth 1 --min-depth 1 --type f --type l \
			--absolute-path --print0 \
			"${search_path_args[@]}" . 2>/dev/null \
			| while IFS= read -r -d $'\0' exe; do
				# fd finds files+symlinks but doesn't check executable bit; verify it
				if [[ -x "$exe" ]]; then
					printf '%s\0' "$exe"
				elif [[ -L "$exe" ]]; then
					local target
					target=$(readlink -f "$exe" 2>/dev/null) || continue
					[[ -n "$target" && -x "$target" && ! -d "$target" ]] && printf '%s\0' "$exe"
				fi
			done
	else
		# Fallback to find
		local perm_flag
		if find /dev/null -executable 2>/dev/null; then
			perm_flag="-executable"
		else
			perm_flag="-perm +111"
		fi
		for dir in "${dirs[@]}"; do
			find -L "$dir" -mindepth 1 -maxdepth 1 -not -type d $perm_flag -print0 2>/dev/null
		done
	fi
}

# Run the function if this script is executed directly
if ! (return 0 2>/dev/null); then
	_script_name="${0##*/}"
	_script_name="${_script_name#-}"
	if [ "$1" = "--test" ]; then
		exec "$HOME/dotfiles/bin/test/${_script_name}_test"
	else
		"$_script_name" "$@"
	fi
fi
